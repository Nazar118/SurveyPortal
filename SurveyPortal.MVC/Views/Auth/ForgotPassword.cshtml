@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifremi Unuttum - SurveyPortal</title>

    <link rel="stylesheet" href="~/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/assets/css/style.css">

    <style>
        body {
            background: linear-gradient(135deg, #f4f7fa 0%, #e2e8f0 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modern-card {
            background: white;
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            width: 100%;
            max-width: 450px;
            text-align: center;
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            background: rgba(182, 109, 255, 0.1);
            color: #b66dff;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin-bottom: 20px;
        }

        .modern-input {
            border: 2px solid #eef0f8;
            border-radius: 12px;
            padding: 15px 20px;
            font-size: 1rem;
            background: #fafbfe;
            transition: all 0.3s ease;
        }

            .modern-input:focus {
                border-color: #b66dff;
                background: #fff;
                box-shadow: 0 0 0 4px rgba(182, 109, 255, 0.1);
            }

        .modern-btn {
            border-radius: 12px;
            padding: 15px;
            font-size: 1.1rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .modern-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(182, 109, 255, 0.3);
            }
    </style>
</head>
<body>

    <div class="modern-card">
        <div class="icon-circle">
            <i class="mdi mdi-lock-question"></i>
        </div>
        <h3 class="font-weight-bold text-dark mb-2">Şifrenizi mi Unuttunuz?</h3>
        <p class="text-muted mb-4">E-posta adresinizi girin, size şifrenizi sıfırlamanız için bir bağlantı gönderelim.</p>

        <form id="forgotPasswordForm">
            <div class="form-group mb-4 text-start">
                <input type="email" class="form-control modern-input" id="email" placeholder="Kayıtlı e-posta adresiniz..." required>
            </div>

            <button type="button" id="btnSend" class="btn btn-gradient-primary btn-block w-100 modern-btn mb-4">
                SIFIRLAMA BAĞLANTISI GÖNDER
            </button>

            <a href="/Auth/Login" class="text-muted font-weight-bold" style="text-decoration: none;">
                <i class="mdi mdi-arrow-left me-1"></i> Giriş Ekranına Dön
            </a>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $("#btnSend").click(function () {
                var emailInput = $("#email").val().trim();

                if (!emailInput) {
                    Swal.fire('Uyarı', 'Lütfen e-posta adresinizi girin.', 'warning');
                    return;
                }

                var btn = $(this);
                btn.prop("disabled", true).html('<i class="mdi mdi-loading mdi-spin"></i> Gönderiliyor...');

                $.ajax({
                    url: "https://localhost:7283/api/auth/forgot-password",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({ email: emailInput }),
                    success: function (res) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Posta Kutunuzu Kontrol Edin!',
                            text: 'Şifre sıfırlama bağlantısı başarıyla gönderildi.',
                            confirmButtonColor: '#b66dff'
                        }).then(() => {
                            window.location.href = "/Auth/Login";
                        });
                    },
                    error: function (xhr) {
                        btn.prop("disabled", false).text("SIFIRLAMA BAĞLANTISI GÖNDER");
                        Swal.fire('Hata!', xhr.responseText || 'Böyle bir e-posta sistemde bulunamadı.', 'error');
                    }
                });
            });
        });
    </script>
</body>
</html>