@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol - SurveyPortal</title>
    <link rel="stylesheet" href="~/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/assets/css/style.css">
    <style>
        body { background: linear-gradient(to right, #b66dff, #4facfe); height: 100vh; display: flex; align-items: center; justify-content: center; }
        .auth-card { background: white; padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); width: 100%; max-width: 500px; }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="text-center mb-4">
            <h2 class="text-primary font-weight-bold">SurveyPortal</h2>
            <p class="text-muted">Aramıza Katılın! Ücretsiz hesap oluşturun.</p>
        </div>

        <form id="registerForm">
            <div class="row">
                <div class="col-md-6 form-group">
                    <input type="text" class="form-control form-control-lg" id="firstName" placeholder="Adınız" required>
                </div>
                <div class="col-md-6 form-group">
                    <input type="text" class="form-control form-control-lg" id="lastName" placeholder="Soyadınız" required>
                </div>
            </div>
            <div class="form-group mb-3">
                <input type="text" class="form-control form-control-lg" id="userName" placeholder="Kullanıcı Adı" required>
            </div>
            <div class="form-group mb-3">
                <input type="email" class="form-control form-control-lg" id="email" placeholder="E-Posta Adresi" required>
            </div>
            <div class="form-group mb-4">
                <input type="password" class="form-control form-control-lg" id="password" placeholder="Şifre" required>
                <small class="text-muted">En az 6 karakter, 1 büyük harf ve 1 rakam içermelidir.</small>
            </div>
            <button type="button" class="btn btn-gradient-primary btn-block btn-lg w-100 font-weight-bold" id="btnRegister">KAYIT OL</button>

            <div class="text-center mt-4 font-weight-light">
                Zaten hesabınız var mı? <a href="/Auth/Login" class="text-primary">Giriş Yap</a>
            </div>
        </form>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            $("#btnRegister").click(function () {
                var btn = $(this);

                var registerData = {
                    firstName: $("#firstName").val().trim(),
                    lastName: $("#lastName").val().trim(),
                    userName: $("#userName").val().trim(),
                    email: $("#email").val().trim(),
                    password: $("#password").val()
                };

                if (!registerData.firstName || !registerData.lastName || !registerData.userName || !registerData.email || !registerData.password) {
                    showErrorToast('Lütfen tüm alanları doldurun!');
                    return;
                }

                btn.prop('disabled', true).text('Kayıt Yapılıyor...');

                $.ajax({
                    url: "https://localhost:7283/api/auth/register",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(registerData),
                    success: function (res) {
                        showSuccessToast('Hesabınız başarıyla oluşturuldu! Giriş sayfasına yönlendiriliyorsunuz...');
                        setTimeout(function() {
                            window.location.href = '/Auth/Login';
                        }, 2000);
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false).text('KAYIT OL');

                        var errorMsg = "Kayıt işlemi başarısız oldu.";
                        if (xhr.responseText) {
                            try {
                                var response = JSON.parse(xhr.responseText);
                                if(Array.isArray(response)) {
                                    errorMsg = response[0].description;
                                } else if (response.message) {
                                    errorMsg = response.message;
                                } else {
                                    errorMsg = xhr.responseText;
                                }
                            } catch (e) {
                                errorMsg = xhr.responseText;
                            }
                        }
                        showErrorToast(errorMsg);
                    }
                });
            });
        });
    </script>
</body>
</html>