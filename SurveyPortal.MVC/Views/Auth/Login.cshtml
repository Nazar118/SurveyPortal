@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row flex-grow w-100">
    <div class="col-lg-4 mx-auto">
        <div class="auth-form-light text-left p-5 shadow rounded">
            <div class="brand-logo mb-4 text-center">
                <h2 class="text-primary font-weight-bold">SurveyPortal</h2>
            </div>
            <h4 class="text-center">Hoş Geldiniz!</h4>
            <h6 class="font-weight-light text-center mb-4">Devam etmek için lütfen giriş yapın.</h6>

            <form class="pt-3" id="loginForm">
                <div class="form-group mb-3">
                    <input type="text" class="form-control form-control-lg" id="username" placeholder="Kullanıcı Adınız" required>
                </div>
                <div class="form-group mb-4">
                    <input type="password" class="form-control form-control-lg" id="password" placeholder="Şifreniz" required>
                </div>
                <div class="mt-3 d-grid gap-2">
                    <button type="button" id="btnLogin" class="btn btn-block btn-gradient-primary btn-lg font-weight-medium auth-form-btn">
                        GİRİŞ YAP
                    </button>
                    <div class="text-center mt-4 font-weight-light">
                        Hesabınız yok mu? <a href="/Auth/Register" class="text-primary">Hemen Kayıt Olun</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#btnLogin").click(function (e) {
                e.preventDefault();

                var usernameInput = $("#username").val();
                var passwordInput = $("#password").val();

                if (!usernameInput || !passwordInput) {
                    alert("Lütfen kullanıcı adı ve şifrenizi giriniz.");
                    return;
                }

                $.ajax({
                    url: "https://localhost:7283/api/auth/login",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify({
                        userName: usernameInput,
                        password: passwordInput
                    }),
                    success: function (res) {
                        // 1. Gelen bileti (Token) ve ROLÜ kaydet
                        localStorage.setItem("token", res.token);
                        localStorage.setItem("userRole", res.role); 

                        var isAdmin = (res.role && res.role.toLowerCase() === "admin");

                        var redirectMessage = isAdmin
                            ? 'Yönetici paneline yönlendiriliyorsunuz...'
                            : 'Ana sayfaya yönlendiriliyorsunuz...';

                        Swal.fire({
                            icon: 'success',
                            title: 'Giriş Başarılı!',
                            text: redirectMessage,
                            showConfirmButton: false,
                            timer: 1500
                        }).then(function() {
                            if (isAdmin) {
                                window.location.href = "/Admin/Index"; 
                            } else {
                                window.location.href = "/Home/Index"; 
                            }
                        });
                    },
                    error: function (xhr) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Giriş Başarısız!',
                            text: 'Kullanıcı adı veya şifre hatalı.',
                            confirmButtonColor: '#b66dff'
                        });
                        console.error(xhr);
                    }
                });
            });
        });
    </script>
}