<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />

    <title>@ViewData["Title"] - SurveyPortal | Fikirlerinle Dünyaya Yön Ver</title>
    <meta name="description" content="Yeni nesil anket platformu SurveyPortal ile ilgini çeken araştırmalara katıl, içgörülerini paylaş ve anında sonuçları gör." />
    <meta name="keywords" content="anket, survey, araştırma, veri analizi, pazar araştırması, kullanıcı deneyimi, geri bildirim" />
    <meta name="author" content="Nazar Berk" />
    <meta name="theme-color" content="#b66dff">
    <link rel="stylesheet" href="~/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/assets/css/style.css">

    <link rel="dns-prefetch" href="https://code.jquery.com">
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">

    <style>
        body {
            background-color: #f4f7fa;
        }

        .navbar.user-navbar {
            background: linear-gradient(to right, #b66dff, #4facfe);
        }

            .navbar.user-navbar .navbar-brand, .navbar.user-navbar .nav-link {
                color: white !important;
                font-weight: bold;
                transition: opacity 0.2s;
            }

                .navbar.user-navbar .nav-link:hover {
                    opacity: 0.8;
                }

        .btn, .form-control, .form-select, .category-chip {
            min-height: 44px !important; 
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        /* 🔥 AŞAMA 7.1: MOBILE CARD SYSTEM (Mobilde düzen) */
        @@media (max-width: 768px) {
            /* Hero alanını mobilde ortala ve küçült */
            .hero-section {
                padding: 2rem 0;
                text-align: center;
            }

                .hero-section h1 {
                    font-size: 2.2rem !important;
                }

                .hero-section .d-flex.align-items-center.mb-5 {
                    flex-direction: column;
                    gap: 15px;
                }

                .hero-section .stat-block {
                    margin-right: 0 !important;
                    width: 100%;
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    border-bottom: 1px solid rgba(0,0,0,0.05);
                    padding-bottom: 10px;
                }
            /* Mobilde kartlar arası boşluğu optimize et */
            .modern-survey-card {
                margin-bottom: 10px;
            }
            /* Mobilde arama ve filtreleme kutularını tam genişlik yap */
            #searchInput, #sortFilter {
                margin-bottom: 10px;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar user-navbar col-lg-12 col-12 p-0 fixed-top d-flex flex-row shadow-sm">
        <div class="container d-flex justify-content-between align-items-center py-3">
            <a class="navbar-brand text-white" href="/Home/Index">
                <i class="mdi mdi-poll-box"></i> SurveyPortal
            </a>
            <ul class="navbar-nav ms-auto flex-row align-items-center" style="gap: 15px;" id="navAuthSection">
            </ul>
        </div>
    </nav>

    <div class="container" style="margin-top: 100px; min-height: 75vh;">
        @RenderBody()
    </div>

    <footer class="footer mt-5 bg-white shadow-sm border-top">
        <div class="container text-center py-3">
            <span class="text-muted">© 2026 SurveyPortal. Tüm hakları saklıdır.</span>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        $(document).ready(function () {
            $("img").attr("loading", "lazy");
            var token = localStorage.getItem("token");
            var authSection = $("#navAuthSection");

            if (token) {
                // Giriş yapmış kullanıcı menüsü
                authSection.html(`
                    <li class="nav-item me-2">
                        <a class="nav-link btn-dark-mode-toggle" href="#" title="Gece/Gündüz Modu" style="font-size: 1.3rem;">
                            <i class="mdi mdi-weather-night darkModeIcon" style="color: white;"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-sm btn-outline-light px-3 rounded-pill" href="/Home/Profile"><i class="mdi mdi-account-circle"></i> Profilim</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" href="#" onclick="globalLogout()"><i class="mdi mdi-logout"></i> Çıkış</a>
                    </li>
                `);
            } else {
                // Misafir kullanıcı menüsü (Giriş yapmamış)
                authSection.html(`
                    <li class="nav-item me-2">
                        <a class="nav-link btn-dark-mode-toggle" href="#" title="Gece/Gündüz Modu" style="font-size: 1.3rem;">
                            <i class="mdi mdi-weather-night darkModeIcon" style="color: white;"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Auth/Login"><i class="mdi mdi-login"></i> Giriş Yap</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-sm btn-light text-primary px-4 rounded-pill font-weight-bold" href="/Auth/Register"><i class="mdi mdi-account-plus"></i> Kayıt Ol</a>
                    </li>
                `);
            }
        });

        function globalLogout() {
            localStorage.removeItem("token");
            localStorage.removeItem("userRole");
            window.location.href = "/Home/Index"; 
        }

        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = localStorage.getItem("token");
                if (token) {
                    xhr.setRequestHeader("Authorization", "Bearer " + token);
                }
            },
            error: function (jqXHR) {
                if (jqXHR.status === 401) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Oturum Gerekli!',
                        text: 'İşleme devam edebilmek için giriş yapmalısınız.'
                    }).then(() => {
                        window.location.href = "/Auth/Login";
                    });
                }
            }
        });
    </script>
</body>
</html>