<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Admin Panel - SurveyPortal</title>
    <link rel="stylesheet" href="~/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/assets/css/style.css">

    <!-- 🔥 YÖNETİCİ PANELİ SABİTLEME VE SCROLL STİLLERİ BURAYA EKLENDİ 🔥 -->
    <style>
        /* Tüm sayfanın dışarıdan kaymasını kilitliyoruz */
        body, html {
            height: 100vh;
            overflow: hidden !important;
        }

        /* Üst Menüyü (Navbar) en üste sabitliyoruz */
        .navbar {
            position: fixed !important;
            top: 0;
            right: 0;
            left: 0;
            z-index: 1030;
        }

        /* Sayfa Gövdesini üst menünün altında başlatıyoruz */
        .page-body-wrapper {
            padding-top: 70px !important;
            height: 100vh;
            display: flex;
        }

        /* Sol Menüyü (Sidebar) sola sabitliyoruz */
        .sidebar {
            position: fixed !important;
            left: 0;
            height: calc(100vh - 70px);
            overflow-y: auto;
            z-index: 1000;
        }

        /* Ana İçerik Alanı - SADECE BURASI KAYACAK */
        .main-panel {
            margin-left: 260px;
            width: calc(100% - 260px);
            height: calc(100vh - 70px);
            overflow-y: auto;
            overflow-x: hidden;
        }

            /* 🔥 ANA İÇERİK ALANI İÇİN ÖZEL ZARİF SCROLLBAR */
            .main-panel::-webkit-scrollbar {
                width: 8px;
            }

            .main-panel::-webkit-scrollbar-track {
                background: rgba(0,0,0,0.02);
            }

            .main-panel::-webkit-scrollbar-thumb {
                background-color: #b66dff;
                border-radius: 10px;
            }

                .main-panel::-webkit-scrollbar-thumb:hover {
                    background-color: #9c4be8;
                }

        /* Dark Mode desteği */
        body.dark-mode .main-panel::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.02);
        }

        body.dark-mode .main-panel::-webkit-scrollbar-thumb {
            background-color: #7922e5;
        }

        @@media (max-width: 991px) {
            .main-panel

        {
            margin-left: 0;
            width: 100%;
        }

        }
    </style>
</head>
<body>
    <div class="container-scroller">

        <nav class="navbar default-layout-navbar col-lg-12 col-12 p-0 fixed-top d-flex flex-row">
            <div class="text-center navbar-brand-wrapper d-flex align-items-center justify-content-center">
                <a class="navbar-brand brand-logo" href="/Admin/Index"><h3 class="text-primary m-0 font-weight-bold">SurveyPortal</h3></a>
            </div>
            <div class="navbar-menu-wrapper d-flex align-items-stretch">
                <ul class="navbar-nav navbar-nav-right d-flex align-items-center">
                    <li class="nav-item me-3">
                        <a class="nav-link btn-dark-mode-toggle" href="#" title="Gece/Gündüz Modu">
                            <i class="mdi mdi-weather-night darkModeIcon text-dark" style="font-size: 1.5rem;"></i>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-danger font-weight-bold" href="#" onclick="logout()" id="btnLogout">
                            <i class="mdi mdi-power"></i> Çıkış Yap
                        </a>
                    </li>
                </ul>
                <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
                    <span class="mdi mdi-menu"></span>
                </button>
            </div>
        </nav>

        <div class="container-fluid page-body-wrapper">

            <nav class="sidebar sidebar-offcanvas" id="sidebar">
                <ul class="nav">
                    <li class="nav-item nav-profile">
                        <a href="#" class="nav-link">
                            <div class="nav-profile-text d-flex flex-column">
                                <span class="font-weight-bold mb-2">Yönetici Paneli</span>
                                <span class="text-secondary text-small">Tam Yetki</span>
                            </div>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Index">
                            <span class="menu-title">Dashboard</span>
                            <i class="mdi mdi-home menu-icon"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/SurveyList">
                            <span class="menu-title">Anket Listesi</span>
                            <i class="mdi mdi-format-list-bulleted menu-icon"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Categories">
                            <span class="menu-title">Kategoriler</span>
                            <i class="mdi mdi-grid menu-icon"></i>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Users">
                            <span class="menu-title">Kullanıcılar</span>
                            <i class="mdi mdi-account-multiple menu-icon"></i>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="main-panel">
                <div class="content-wrapper">

                    @RenderBody()

                </div>
                <footer class="footer">
                    <div class="container-fluid d-flex justify-content-between">
                        <span class="text-muted d-block text-center text-sm-start d-sm-inline-block">Copyright © SurveyPortal 2026</span>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/assets/vendors/js/vendor.bundle.base.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/assets/js/off-canvas.js"></script>
    <script src="~/assets/js/misc.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        function logout() {
            localStorage.removeItem("token");
            localStorage.removeItem("userRole");
            window.location.replace("/Auth/Login");
        }
    </script>
</body>
</html>