@{
    ViewData["Title"] = "Kullanıcı Paneli";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    /* 🔥 PORTAL CSS (Mevcut tasarım aynen korundu) */
    .portal-sidebar {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        height: 100%;
        min-height: 70vh;
    }

    .portal-avatar {
        width: 90px;
        height: 90px;
        font-size: 3rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: linear-gradient(45deg, #b66dff, #d8a7ff);
        color: white;
        box-shadow: 0 4px 10px rgba(182, 109, 255, 0.3);
    }

    .nav-pills .nav-link {
        color: #444;
        border-radius: 10px;
        padding: 14px 20px;
        font-weight: 500;
        margin-bottom: 8px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
    }

        .nav-pills .nav-link i {
            font-size: 1.2rem;
            margin-right: 12px;
            color: #888;
            transition: all 0.3s ease;
        }

        .nav-pills .nav-link:hover:not(.active) {
            background-color: #f8f9fc;
            color: #b66dff;
            transform: translateX(5px);
        }

            .nav-pills .nav-link:hover:not(.active) i {
                color: #b66dff;
            }

        .nav-pills .nav-link.active {
            background: linear-gradient(to right, #b66dff, #9834ff);
            color: white !important;
            box-shadow: 0 4px 10px rgba(182, 109, 255, 0.4);
        }

            .nav-pills .nav-link.active i {
                color: white;
            }

    .portal-content {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        padding: 40px;
        min-height: 70vh;
    }

    .survey-list-item {
        transition: all 0.2s ease;
        border-left: 4px solid transparent;
    }

        .survey-list-item:hover {
            background-color: #fcfcfc;
            border-left-color: #b66dff;
        }

    /* Yeni Form Input Tasarımı */
    .form-control:focus {
        border-color: #b66dff;
        box-shadow: 0 0 0 0.2rem rgba(182, 109, 255, 0.25);
    }
    .skeleton-box {
        background: #e2e5e7;
        background-image: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
        background-size: 40px 100%;
        background-repeat: no-repeat;
        background-position: left -40px top 0;
        animation: shimmer 1.5s infinite;
        border-radius: 6px;
    }

    @@keyframes shimmer {
        100% {
            background-position: right -40px top 0;
        }
    }

    body.dark-mode .skeleton-box {
        background-color: #2c2c2c;
    }

    .fade-in-up {
        animation: fadeInUp 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
        opacity: 0;
        transform: translateY(20px);
    }
    /* Kartların sırayla düşmesi için gecikme (delay) tanımları */
    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }

    @@keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container-fluid mt-4 mb-5" style="max-width: 1400px;">
    <div class="row g-4">

        <!-- 🔥 SOL MENÜ -->
        <div class="col-lg-3 col-md-4">
            <div class="portal-sidebar p-4">
                <div class="text-center mb-4 pb-4 border-bottom">
                    <div class="portal-avatar mb-3"><i class="mdi mdi-account"></i></div>
                    <h5 class="font-weight-bold text-dark mb-1" id="sideUsername">Yükleniyor...</h5>
                    <span class="badge badge-outline-primary badge-pill px-3 py-1" id="sideRole">...</span>
                </div>

                <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                    <button class="nav-link active" id="v-pills-surveys-tab" data-bs-toggle="pill" data-bs-target="#v-pills-surveys" type="button" role="tab">
                        <i class="mdi mdi-format-list-checks"></i> Katıldığım Anketler
                    </button>
                    <button class="nav-link" id="v-pills-profile-tab" data-bs-toggle="pill" data-bs-target="#v-pills-profile" type="button" role="tab">
                        <i class="mdi mdi-card-account-details-outline"></i> Hesap Bilgilerim
                    </button>
                    <!-- 🔥 YENİ: Şifre Değiştir Sekmesi -->
                    <button class="nav-link" id="v-pills-password-tab" data-bs-toggle="pill" data-bs-target="#v-pills-password" type="button" role="tab">
                        <i class="mdi mdi-lock-reset"></i> Şifre Değiştir
                    </button>

                    <hr class="my-3">
                    <a href="/Home/Index" class="nav-link text-dark" style="background: transparent;"><i class="mdi mdi-compass-outline"></i> Yeni Anket Keşfet</a>
                    <button class="nav-link text-danger mt-2" onclick="logout()" style="background: transparent;"><i class="mdi mdi-logout text-danger"></i> Güvenli Çıkış</button>
                </div>
            </div>
        </div>

        <!-- 🔥 SAĞ İÇERİK ALANI -->
        <div class="col-lg-9 col-md-8">
            <div class="portal-content">
                <div class="tab-content" id="v-pills-tabContent">

                    <!-- TAB 1: ANKETLERİM -->
                    <div class="tab-pane fade show active" id="v-pills-surveys" role="tabpanel">
                        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                            <h3 class="font-weight-bold m-0"><i class="mdi mdi-check-network text-success me-2"></i> Anket Geçmişim</h3>
                        </div>
                        <div id="mySurveysList">
                            <div class="survey-list-item d-flex justify-content-between align-items-center py-4 px-3 border-bottom">
                                <div style="width: 60%;">
                                    <div class="skeleton-box mb-2" style="width: 80%; height: 20px;"></div>
                                    <div class="skeleton-box" style="width: 40%; height: 14px;"></div>
                                </div>
                                <div class="skeleton-box" style="width: 120px; height: 35px; border-radius: 50px;"></div>
                            </div>
                            <div class="survey-list-item d-flex justify-content-between align-items-center py-4 px-3 border-bottom">
                                <div style="width: 60%;">
                                    <div class="skeleton-box mb-2" style="width: 60%; height: 20px;"></div>
                                    <div class="skeleton-box" style="width: 30%; height: 14px;"></div>
                                </div>
                                <div class="skeleton-box" style="width: 120px; height: 35px; border-radius: 50px;"></div>
                            </div>
                        </div>
                    </div>

                    <!-- TAB 2: HESAP BİLGİLERİM (Artık Güncellenebilir Form) -->
                    <div class="tab-pane fade" id="v-pills-profile" role="tabpanel">
                        <h3 class="font-weight-bold mb-4 pb-2 border-bottom"><i class="mdi mdi-shield-account-outline text-primary me-2"></i> Hesap Detayları</h3>

                        <form id="profileUpdateForm">
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label class="text-muted font-weight-bold mb-2">Kullanıcı Adı</label>
                                    <input type="text" class="form-control form-control-lg bg-light border-1" id="detailUsername" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="text-muted font-weight-bold mb-2">E-Posta Adresi</label>
                                    <input type="email" class="form-control form-control-lg bg-light border-1" id="detailEmail" required>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="text-muted font-weight-bold mb-2">Yetki Seviyesi</label>
                                    <div class="form-control form-control-lg bg-light border-0 text-primary font-weight-bold" id="detailRole">...</div>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="text-muted font-weight-bold mb-2">Hesap Durumu</label>
                                    <div class="form-control form-control-lg bg-light border-0 text-success font-weight-bold"><i class="mdi mdi-check-circle"></i> Aktif</div>
                                </div>
                            </div>
                            <div class="text-end">
                                <button type="button" id="btnUpdateProfile" class="btn btn-gradient-primary px-5 py-3 rounded-pill font-weight-bold shadow-sm">
                                    <i class="mdi mdi-content-save me-1"></i> Bilgilerimi Güncelle
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- 🔥 YENİ TAB 3: ŞİFRE DEĞİŞTİR -->
                    <div class="tab-pane fade" id="v-pills-password" role="tabpanel">
                        <h3 class="font-weight-bold mb-4 pb-2 border-bottom"><i class="mdi mdi-lock-reset text-danger me-2"></i> Şifre Değiştir</h3>

                        <div class="row">
                            <div class="col-md-8">
                                <form id="passwordChangeForm">
                                    <div class="form-group mb-4">
                                        <label class="text-muted font-weight-bold mb-2">Mevcut Şifreniz</label>
                                        <input type="password" class="form-control form-control-lg bg-light border-1" id="currentPassword" placeholder="Şu anki şifrenizi girin..." required>
                                    </div>
                                    <div class="form-group mb-4">
                                        <label class="text-muted font-weight-bold mb-2">Yeni Şifre</label>
                                        <input type="password" class="form-control form-control-lg bg-light border-1" id="newPassword" placeholder="Yeni şifrenizi belirleyin..." required>
                                    </div>
                                    <div class="form-group mb-4">
                                        <label class="text-muted font-weight-bold mb-2">Yeni Şifre (Tekrar)</label>
                                        <input type="password" class="form-control form-control-lg bg-light border-1" id="newPasswordConfirm" placeholder="Yeni şifrenizi tekrar girin..." required>
                                    </div>
                                    <button type="button" id="btnChangePassword" class="btn btn-outline-danger px-5 py-3 rounded-pill font-weight-bold shadow-sm">
                                        <i class="mdi mdi-shield-check me-1"></i> Şifreyi Güncelle
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadUserProfile();

            // Tab Geçişlerini Sağlama
            $(".nav-pills .nav-link").click(function () {
                if($(this).attr("id")) {
                    $(".nav-pills .nav-link").removeClass("active");
                    $(this).addClass("active");
                    var target = $(this).attr("data-bs-target") || $(this).attr("data-target");
                    $(".tab-pane").removeClass("show active");
                    $(target).addClass("show active");
                }
            });

            // 🔥 PROFİL GÜNCELLEME İŞLEMİ
            $("#btnUpdateProfile").click(function () {
                var btn = $(this);
                var token = localStorage.getItem("token");
                var username = $("#detailUsername").val().trim();
                var email = $("#detailEmail").val().trim();

                if (!username || !email) {
                    showErrorToast('Lütfen kullanıcı adı ve e-posta alanlarını doldurun.');
                    return;
                }

                btn.prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin"></i> Güncelleniyor...');

                $.ajax({
                    url: "https://localhost:7283/api/user/update-profile",
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ userName: username, email: email }),
                    success: function (res) {
                        btn.prop('disabled', false).html('<i class="mdi mdi-content-save me-1"></i> Bilgilerimi Güncelle');
                        $("#sideUsername").text(username);
                        showSuccessToast('Profil bilgileriniz başarıyla güncellendi.');
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false).html('<i class="mdi mdi-content-save me-1"></i> Bilgilerimi Güncelle');
                        showErrorToast(xhr.responseText || 'Güncelleme sırasında bir hata oluştu.');
                    }
                });
            });

            // 🔥 ŞİFRE DEĞİŞTİRME İŞLEMİ
            $("#btnChangePassword").click(function () {
                var btn = $(this);
                var token = localStorage.getItem("token");
                var currentPass = $("#currentPassword").val();
                var newPass = $("#newPassword").val();
                var newPassConfirm = $("#newPasswordConfirm").val();

                if (!currentPass || !newPass || !newPassConfirm) {
                    showErrorToast('Lütfen tüm şifre alanlarını doldurun.');
                    return;
                }

                if (newPass !== newPassConfirm) {
                    showErrorToast('Yeni şifre ile tekrarı birbiriyle eşleşmiyor!');
                    return;
                }

                btn.prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin"></i> İşleniyor...');

                $.ajax({
                    url: "https://localhost:7283/api/user/change-password",
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ currentPassword: currentPass, newPassword: newPass }),
                    success: function (res) {
                        btn.prop('disabled', false).html('<i class="mdi mdi-shield-check me-1"></i> Şifreyi Güncelle');
                        $("#currentPassword, #newPassword, #newPasswordConfirm").val('');
                        showSuccessToast('Şifreniz güvenli bir şekilde değiştirildi.');
                    },
                    error: function (xhr) {
                        btn.prop('disabled', false).html('<i class="mdi mdi-shield-check me-1"></i> Şifreyi Güncelle');
                        showErrorToast(xhr.responseText || 'Şifreniz değiştirilemedi.');
                    }
                });
            });
        });

        // Verileri Getirme İşlemi
        function loadUserProfile() {
            var token = localStorage.getItem("token");
            if (!token) { window.location.href = "/Auth/Login"; return; }

            $.ajax({
                url: "https://localhost:7283/api/user/me",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    $("#sideUsername").text(data.username);
                    $("#sideRole").text(data.role);

                    $("#detailUsername").val(data.username);
                    $("#detailEmail").val(data.email);
                    $("#detailRole").text(data.role);

                    var listContainer = $("#mySurveysList");
                    listContainer.empty();

                    if (data.participatedSurveys.length === 0) {
                        listContainer.html(`
                            <div class="text-center py-5">
                                <i class="mdi mdi-text-box-search-outline text-muted" style="font-size: 5rem;"></i>
                                <h4 class="mt-3 text-muted">Burası biraz ıssız...</h4>
                                <a href="/Home/Index" class="btn btn-gradient-primary mt-2 px-4 rounded-pill">Anketleri Keşfet</a>
                            </div>
                        `);
                        return;
                    }

                   $.each(data.participatedSurveys, function (index, survey) {
                        var date = new Date(survey.completedDate).toLocaleDateString("tr-TR", { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute:'2-digit' });

                        var delayClass = "delay-" + ((index % 3) + 1);

                        var item = `
                            <div class="survey-list-item fade-in-up ${delayClass} d-flex justify-content-between align-items-center py-4 px-3 border-bottom rounded">
                                <div>
                                    <h5 class="font-weight-bold mb-1 text-dark">${survey.surveyTitle}</h5>
                                    <span class="text-muted" style="font-size: 0.9rem;">
                                        <i class="mdi mdi-calendar-check text-success me-1"></i> Katılım: ${date}
                                    </span>
                                </div>
                                <div>
                                    <a href="/Home/UserResult/${survey.surveyId}" class="btn btn-outline-primary rounded-pill px-4 shadow-sm font-weight-bold d-flex align-items-center justify-content-center">
                                        <span>Sonuçlar</span>
                                        <i class="mdi mdi-arrow-right ms-2" style="font-size: 1.1rem; transform: translateY(1px);"></i>
                                    </a>
                                </div>
                            </div>
                        `;
                        listContainer.append(item);
                    });
                },
                error: function () { logout(); }
            });
        }

        function logout() {
            localStorage.removeItem("token");
            localStorage.removeItem("userRole");
            window.location.href = "/Home/Index";
        }
    </script>
}