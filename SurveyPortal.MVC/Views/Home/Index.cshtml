@{
    ViewData["Title"] = "Anketler";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="text-center mb-5">
    <h1 class="display-4 font-weight-bold text-primary">Güncel Anketler</h1>
    <p class="text-muted lead">Fikriniz bizim için değerli. Lütfen aşağıdan katılmak istediğiniz anketi seçin.</p>
</div>

<div class="row" id="userSurveyList">
    <div class="col-12 text-center py-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <h4 class="mt-3 text-muted">Anketler Yükleniyor...</h4>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadUserSurveys();
        });

        function loadUserSurveys() {
            $.ajax({
                url: "https://localhost:7283/api/survey",
                type: "GET",
                success: function (data) {
                    var container = $("#userSurveyList");
                    container.empty();
                    var activeSurveys = data;

                    if (activeSurveys.length === 0) {
                        container.append(`
                            <div class="col-12 text-center py-5">
                                <i class="mdi mdi-flask-empty text-muted" style="font-size: 4rem;"></i>
                                <h3 class="text-muted mt-3">Şu an aktif bir anket bulunmuyor.</h3>
                            </div>
                        `);
                        return;
                    }

                    $.each(activeSurveys, function (index, survey) {
                        var desc = survey.description ? survey.description : "Bu anket için henüz bir açıklama girilmemiş.";
                        var date = survey.createdDate ? new Date(survey.createdDate).toLocaleDateString("tr-TR") : "-";

                        var card = `
                            <div class="col-md-4 mb-4 stretch-card grid-margin">
                                <div class="card shadow-sm border-0 h-100" style="transition: transform 0.3s; cursor:pointer;" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="badge badge-info badge-pill">Yeni</span>
                                            <small class="text-muted"><i class="mdi mdi-calendar"></i> ${date}</small>
                                        </div>
                                        <h4 class="card-title text-primary font-weight-bold mb-3">${survey.title}</h4>
                                        <p class="text-muted mb-4" style="flex-grow: 1;">${desc}</p>
                                        <button class="btn btn-gradient-primary btn-block btn-lg" onclick="solveSurvey('${survey.id}')">
                                            Anketi Çöz <i class="mdi mdi-arrow-right ms-2"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(card);
                    });
                },
                error: function (xhr) {
                    console.error("Anketler çekilemedi:", xhr);
                    $("#userSurveyList").html('<div class="col-12 text-center text-danger"><h3>Bağlantı hatası oluştu!</h3></div>');
                }
            });
        }

        function solveSurvey(id) {
            window.location.href = '/Home/SurveyDetail/' + id;
        }
    </script>
}