@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    /* 🔥 UX İYİLEŞTİRMELERİ */
    .survey-card {
        transition: all 0.3s ease-in-out;
        border: 1px solid #ebedf2;
        border-radius: 12px;
    }

        .survey-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            border-color: #b66dff;
        }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .skeleton {
        background-color: #e2e5e7;
        background-image: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
        background-size: 40px 100%;
        background-repeat: no-repeat;
        background-position: left -40px top 0;
        animation: shine 1.2s ease infinite;
        border-radius: 6px;
    }

    @@keyframes shine {
        to {
            background-position: right -40px top 0;
        }
    }

    .skeleton-text {
        height: 16px;
        margin-bottom: 8px;
        width: 100%;
    }

    .skeleton-title {
        height: 24px;
        margin-bottom: 16px;
        width: 70%;
    }

    .skeleton-btn {
        height: 45px;
        width: 100%;
        border-radius: 8px;
        margin-top: 15px;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="row mb-4 align-items-center">
        <div class="col-md-6 d-flex align-items-center justify-content-between">
            <div>
                <h2 class="font-weight-bold text-dark mb-2">Anketleri Keşfet</h2>
                <p class="text-muted">Fikriniz bizim için çok değerli. Kategoriye göre arayın ve katılın.</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="row g-2">
                <div class="col-md-5">
                    <div class="input-group shadow-sm border-0 rounded">
                        <span class="input-group-text bg-white border-0"><i class="mdi mdi-magnify text-muted"></i></span>
                        <input type="text" id="searchInput" class="form-control border-0 bg-white" placeholder="Anket ara...">
                    </div>
                </div>
                <div class="col-md-4">
                    <select id="categoryFilter" class="form-select shadow-sm border-0 bg-white">
                        <option value="">Tüm Kategoriler</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="sortFilter" class="form-select shadow-sm border-0 bg-white">
                        <option value="new">En Yeni</option>
                        <option value="popular">En Popüler</option>
                        <option value="ending">Bitmek Üzere</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="row" id="userSurveyList">
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadCategories();
            loadActiveSurveys();

            $("#searchInput").on("keyup", debounce(function() { loadActiveSurveys(); }, 500));
            $("#categoryFilter, #sortFilter").change(function() { loadActiveSurveys(); });
        });

        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        function loadCategories() {
            $.ajax({
                url: "https://localhost:7283/api/category",
                type: "GET",
                success: function (data) {
                    var select = $("#categoryFilter");
                    $.each(data, function (index, item) {
                        select.append(`<option value="${item.id}">${item.name}</option>`);
                    });
                }
            });
        }

        function loadActiveSurveys() {
            var container = $("#userSurveyList");

            container.empty();
            for(let i=0; i<3; i++){
                container.append(`
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm border-0 h-100 p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <div class="skeleton" style="width: 60px; height: 20px;"></div>
                                <div class="skeleton" style="width: 80px; height: 16px;"></div>
                            </div>
                            <div class="skeleton skeleton-title"></div>
                            <div class="skeleton skeleton-text"></div>
                            <div class="skeleton skeleton-text" style="width:80%;"></div>
                            <div class="skeleton skeleton-text mt-3" style="width:40%;"></div>
                            <div class="skeleton skeleton-btn"></div>
                        </div>
                    </div>
                `);
            }

            var catId = $("#categoryFilter").val();
            var search = $("#searchInput").val();
            var sort = $("#sortFilter").val();

            $.ajax({
                url: `https://localhost:7283/api/survey/active?categoryId=${catId}&search=${search}&sortBy=${sort}`,
                type: "GET",
                success: function (data) {
                    container.empty();

                    if (data.length === 0) {
                        container.append(`
                            <div class="col-12 text-center py-5">
                                <div class="mb-3"><i class="mdi mdi-text-box-search-outline text-muted" style="font-size: 5rem;"></i></div>
                                <h4 class="text-muted font-weight-bold">Sonuç Bulunamadı</h4>
                                <p class="text-muted">Seçtiğiniz filtrelere uygun aktif bir anket bulunmuyor.</p>
                            </div>
                        `);
                        return;
                    }

                    $.each(data, function (index, survey) {
                        var desc = survey.description ? survey.description : "Bu anket için henüz bir açıklama girilmemiş.";
                        var date = survey.endDate
                            ? `<span class="text-danger"><i class="mdi mdi-clock-alert-outline"></i> Son: ${new Date(survey.endDate).toLocaleDateString("tr-TR")}</span>`
                            : `<span class="text-muted"><i class="mdi mdi-calendar"></i> Süresiz</span>`;

                        var btnHtml = "";
                        var participatedBadge = "";

                        if (survey.isParticipated) {
                            participatedBadge = `<div class="position-absolute" style="top: -10px; right: -10px; z-index: 10;">
                                                    <span class="badge bg-success shadow" style="font-size:0.8rem; border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;"><i class="mdi mdi-check text-white" style="font-size: 1.2rem;"></i></span>
                                                 </div>`;
                            btnHtml = `<a href="/Home/UserResult/${survey.id}" class="btn btn-outline-success btn-block w-100 py-3 font-weight-bold">
                                           <i class="mdi mdi-chart-bar"></i> Sonuçları İncele
                                       </a>`;
                        } else {
                            btnHtml = `<button class="btn btn-gradient-primary btn-block w-100 py-3 font-weight-bold" onclick="solveSurvey('${survey.id}')">
                                           Anketi Çöz <i class="mdi mdi-arrow-right ms-2"></i>
                                       </button>`;
                        }

                        var card = `
                            <div class="col-md-4 mb-4">
                                <div class="card survey-card h-100 bg-white position-relative">
                                    ${participatedBadge}
                                    <div class="card-body d-flex flex-column p-4">

                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <span class="badge badge-outline-primary shadow-sm px-3 py-2">${survey.categoryName}</span>
                                            <small class="font-weight-bold">${date}</small>
                                        </div>

                                        <h4 class="card-title text-dark font-weight-bold mb-2 line-clamp-2" style="font-size: 1.2rem; line-height: 1.4;">${survey.title}</h4>
                                        <p class="text-muted mb-4 line-clamp-2" style="font-size: 0.9rem;">${desc}</p>

                                        <div class="mt-auto">
                                            <div class="d-flex align-items-center mb-3 text-muted" style="font-size:0.85rem;">
                                                <i class="mdi mdi-account-group me-1 text-primary"></i>
                                                <span class="font-weight-bold text-dark me-1">${survey.participantCount}</span> kişi katıldı
                                            </div>
                                            ${btnHtml}
                                        </div>

                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(card);
                    });
                },
                error: function (xhr) {
                    container.html('<div class="col-12 text-center py-5 text-danger"><i class="mdi mdi-alert-circle-outline" style="font-size:3rem;"></i><h5>Sistemsel bir hata oluştu!</h5></div>');
                }
            });
        }

               function solveSurvey(id) {
            window.location.href = '/Home/SurveyDetail/' + id;
        }
    </script>
}