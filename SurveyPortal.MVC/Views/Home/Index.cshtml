@{
    ViewData["Title"] = "Keşfet";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    /* 🔥 AŞAMA 1: HERO SECTION & MODERN UX İYİLEŞTİRMELERİ */
    .hero-section {
        padding: 4rem 0;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        position: relative;
        overflow: hidden;
    }

    body.dark-mode .hero-section {
        border-bottom: 1px solid #333;
    }

    .stat-block h3 {
        font-size: 2.2rem;
        margin-bottom: 0;
        line-height: 1;
    }

    .stat-block span {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: bold;
    }

    .trending-card {
        background: linear-gradient(135deg, #b66dff 0%, #7922e5 100%);
        border-radius: 20px;
        color: white;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(182, 109, 255, 0.3);
        transform: perspective(1000px) rotateY(-5deg);
        transition: transform 0.4s ease, box-shadow 0.4s ease;
    }

        .trending-card:hover {
            transform: perspective(1000px) rotateY(0deg) translateY(-10px);
            box-shadow: 0 30px 50px rgba(182, 109, 255, 0.5);
        }

        .trending-card::before {
            content: '\F02A4';
            font-family: "Material Design Icons";
            position: absolute;
            font-size: 14rem;
            right: -30px;
            top: -40px;
            opacity: 0.1;
            transform: rotate(15deg);
        }

    .survey-card {
        transition: all 0.3s ease-in-out;
        border: 1px solid #ebedf2;
        border-radius: 12px;
    }

        .survey-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            border-color: #b66dff;
        }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .skeleton {
        background-color: #e2e5e7;
        background-image: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0));
        background-size: 40px 100%;
        background-repeat: no-repeat;
        background-position: left -40px top 0;
        animation: shine 1.2s ease infinite;
        border-radius: 6px;
    }

    body.dark-mode .skeleton {
        background-color: #2c2c2c;
    }

    @@keyframes shine {
        to {
            background-position: right -40px top 0;
        }
    }

    .skeleton-text {
        height: 16px;
        margin-bottom: 8px;
        width: 100%;
    }

    .skeleton-title {
        height: 24px;
        margin-bottom: 16px;
        width: 70%;
    }

    .skeleton-btn {
        height: 45px;
        width: 100%;
        border-radius: 8px;
        margin-top: 15px;
    }

    /* 🔥 KATEGORİ CHIP SİSTEMİ */
    .category-chip-container {
        overflow-x: auto;
        white-space: nowrap;
        padding-bottom: 10px;
        scrollbar-width: none;
        gap: 12px;
    }

        .category-chip-container::-webkit-scrollbar {
            display: none;
        }

    .category-chip {
        background-color: #fff;
        border: 1px solid #ebedf2;
        color: #6c757d;
        padding: 10px 24px;
        border-radius: 30px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        flex-shrink: 0;
    }

        .category-chip:hover {
            border-color: #b66dff;
            color: #b66dff;
        }

        .category-chip.active {
            background: linear-gradient(135deg, #b66dff 0%, #7922e5 100%);
            color: #fff;
            border: none;
            box-shadow: 0 5px 15px rgba(182, 109, 255, 0.4);
        }

    body.dark-mode .category-chip {
        background-color: #1e1e1e;
        border-color: #333;
        color: #a0a0a0;
    }

        body.dark-mode .category-chip:hover {
            color: #b66dff;
            border-color: #b66dff;
        }

        body.dark-mode .category-chip.active {
            color: #fff;
        }

    /* 🔥 MODERN SURVEY CARD SİSTEMİ */
    .modern-survey-card {
        background: #ffffff;
        border: 1px solid #ebedf2;
        border-radius: 16px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        display: flex;
        flex-direction: column;
    }

        .modern-survey-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(182, 109, 255, 0.15) !important;
            border-color: #b66dff;
        }

    .card-badge-container {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .mini-progress-bg {
        background: #e9ecef;
        border-radius: 4px;
        height: 6px;
        width: 100%;
        overflow: hidden;
    }

    .mini-progress-fill {
        background: linear-gradient(90deg, #b66dff, #4facfe);
        height: 100%;
        border-radius: 4px;
    }

    .card-footer-stats {
        margin-top: auto;
        border-top: 1px solid rgba(0,0,0,0.05);
        padding-top: 1.2rem;
    }

    body.dark-mode .modern-survey-card {
        background: #1e1e1e;
        border-color: #333;
    }

        body.dark-mode .modern-survey-card:hover {
            box-shadow: 0 20px 40px rgba(182, 109, 255, 0.3) !important;
        }

    body.dark-mode .card-footer-stats {
        border-top-color: rgba(255,255,255,0.05);
    }

    body.dark-mode .mini-progress-bg {
        background: #333;
    }
</style>

<!-- 🔥 YENİ HERO SECTION BAŞLANGICI -->
<section class="hero-section mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <span class="badge badge-outline-primary rounded-pill px-3 py-2 mb-3 font-weight-bold">🚀 Yeni Nesil Anket Platformu</span>
                <h1 class="display-4 font-weight-bold text-dark mb-4" style="line-height: 1.2;">
                    Fikirlerinle <span class="text-primary">Dünyaya</span><br />Yön Ver.
                </h1>
                <p class="lead text-muted mb-5" style="font-size: 1.15rem;">
                    Platformumuzdaki binlerce katılımcı arasına katıl. İlgini çeken araştırmaları keşfet, anketleri çöz ve değişimin bir parçası ol.
                </p>

                <div class="d-flex align-items-center mb-5">
                    <div class="stat-block me-5">
                        <h3 class="text-dark font-weight-bold" id="heroTotalSurvey">-</h3>
                        <span class="text-muted">Aktif Anket</span>
                    </div>
                    <div class="stat-block me-5">
                        <h3 class="text-dark font-weight-bold" id="heroTotalCategory">-</h3>
                        <span class="text-muted">Kategori</span>
                    </div>
                    <div class="stat-block">
                        <h3 class="text-success font-weight-bold" id="heroTodayParticipants">-</h3>
                        <span class="text-muted">Bugünkü Katılım</span>
                    </div>
                </div>

                <button class="btn btn-gradient-primary btn-lg px-5 py-3 rounded-pill font-weight-bold shadow" onclick="document.getElementById('exploreSection').scrollIntoView({behavior: 'smooth'})">
                    Hemen Keşfet <i class="mdi mdi-arrow-down ms-2"></i>
                </button>
            </div>

            <div class="col-lg-5 offset-lg-1">
                <div class="trending-card" id="trendingCardBlock">
                    <div class="mb-4">
                        <span class="badge bg-white text-primary rounded-pill px-3 py-2 font-weight-bold shadow-sm">
                            <i class="mdi mdi-fire text-danger"></i> Haftanın En Popüler Anketi
                        </span>
                    </div>
                    <h2 class="font-weight-bold mb-4 line-clamp-2" id="trendSurveyTitle" style="line-height: 1.3;">Yükleniyor...</h2>

                    <div class="d-flex align-items-center mb-5">
                        <div class="d-flex align-items-center bg-white bg-opacity-25 rounded-pill px-3 py-2">
                            <i class="mdi mdi-account-group me-2" style="font-size: 1.2rem;"></i>
                            <span class="font-weight-bold h5 mb-0" id="trendSurveyCount">-</span> <span class="ms-1 opacity-75">kişi katıldı</span>
                        </div>
                    </div>

                    <button class="btn btn-light btn-lg w-100 text-primary font-weight-bold rounded-pill shadow-sm" id="btnGoTrendSurvey" onclick="" disabled>
                        Bu Anketi Çöz
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- HERO SECTION BİTİŞİ -->

<div class="container mb-5" id="exploreSection">
    <div class="row mb-4 align-items-end">
        <div class="col-md-6 mb-3 mb-md-0">
            <h3 class="font-weight-bold text-dark mb-1"><i class="mdi mdi-compass-outline text-primary me-2"></i> Anketleri Keşfet</h3>
            <p class="text-muted m-0">Senin için hazırlanan güncel anketler aşağıda listeleniyor.</p>
        </div>

        <!-- ARAMA VE SIRALAMA ALANI -->
        <div class="col-md-6">
            <div class="row g-2 justify-content-end">
                <div class="col-md-7">
                    <div class="input-group shadow-sm border-0 rounded h-100">
                        <span class="input-group-text bg-white border-0"><i class="mdi mdi-magnify text-muted"></i></span>
                        <input type="text" id="searchInput" class="form-control border-0 bg-white" placeholder="Anket ara...">
                    </div>
                </div>
                <div class="col-md-5">
                    <select id="sortFilter" class="form-select shadow-sm border-0 bg-white h-100">
                        <option value="new">En Yeni</option>
                        <option value="popular">En Popüler</option>
                        <option value="ending">Bitmek Üzere</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- 🔥  KATEGORİ CHIP SİSTEMİ -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="category-chip-container d-flex" id="categoryChips">
                <button class="category-chip active" data-id="">🔥 Tümü</button>
            </div>
        </div>
    </div>

    <!-- ANKET LİSTESİ -->
    <div class="row" id="userSurveyList">
        <!-- Anketler Buraya Gelecek -->
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadHeroStatistics();
            loadCategories();
            loadActiveSurveys();

            $("#searchInput").on("keyup", debounce(function() { loadActiveSurveys(); }, 500));
            $("#sortFilter").change(function() { loadActiveSurveys(); });
        });

        function loadHeroStatistics() {
            $.ajax({
                url: "https://localhost:7283/api/dashboard/overview",
                type: "GET",
                success: function (data) {
                    $("#heroTotalSurvey").text(data.totalSurvey);
                    $("#heroTotalCategory").text(data.totalCategory);
                    $("#heroTodayParticipants").text(data.todayParticipants);

                    if(data.trendingSurvey) {
                        $("#trendSurveyTitle").text(data.trendingSurvey.title);
                        $("#trendSurveyCount").text(data.trendingSurvey.participantCount);
                        $("#btnGoTrendSurvey").prop("disabled", false).attr("onclick", `solveSurvey('${data.trendingSurvey.id}')`);
                    } else {
                        $("#trendSurveyTitle").text("Şu an popüler anket yok");
                        $("#btnGoTrendSurvey").hide();
                    }
                }
            });
        }

        function debounce(func, wait) {
            let timeout;
            return function(...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        function loadCategories() {
             $.ajax({
                 url: "https://localhost:7283/api/category",
                 type: "GET",
                 success: function (data) {
                     var container = $("#categoryChips");
                     container.empty();
                     container.append(`<button class="category-chip active" data-id="">🔥 Tümü</button>`);
                     $.each(data, function (index, item) {
                         container.append(`<button class="category-chip" data-id="${item.id}">${item.name}</button>`);
                     });
                 }
             });
         }

        $(document).on("click", ".category-chip", function() {
            $(".category-chip").removeClass("active");
            $(this).addClass("active");
            loadActiveSurveys();
        });

        function loadActiveSurveys() {
            var container = $("#userSurveyList");
            container.empty();

            for(let i=0; i<3; i++){
                container.append(`
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm border-0 h-100 p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <div class="skeleton" style="width: 60px; height: 20px;"></div>
                                <div class="skeleton" style="width: 80px; height: 16px;"></div>
                            </div>
                            <div class="skeleton skeleton-title"></div>
                            <div class="skeleton skeleton-text"></div>
                            <div class="skeleton skeleton-text" style="width:80%;"></div>
                            <div class="skeleton skeleton-text mt-3" style="width:40%;"></div>
                            <div class="skeleton skeleton-btn"></div>
                        </div>
                    </div>
                `);
            }

            var catId = $(".category-chip.active").attr("data-id") || "";
            var search = $("#searchInput").val();
            var sort = $("#sortFilter").val();

            $.ajax({
                url: `https://localhost:7283/api/survey/active?categoryId=${catId}&search=${search}&sortBy=${sort}`,
                type: "GET",
                success: function (data) {
                    container.empty();

                    if (data.length === 0) {
                        container.append(`
                            <div class="col-12 text-center py-5">
                                <div class="mb-3"><i class="mdi mdi-text-box-search-outline text-muted" style="font-size: 5rem;"></i></div>
                                <h4 class="text-muted font-weight-bold">Sonuç Bulunamadı</h4>
                                <p class="text-muted">Seçtiğiniz filtrelere uygun aktif bir anket bulunmuyor.</p>
                            </div>
                        `);
                        return;
                    }

                    $.each(data, function (index, survey) {
                        var desc = survey.description ? survey.description : "Bu anket için henüz bir açıklama girilmemiş.";
                        var estTime = survey.estimatedTime || 3;
                        var compRate = survey.completionRate || 85;

                        var statusBadges = "";
                        var diffDays = Math.floor((new Date() - new Date(survey.createdDate)) / (1000 * 60 * 60 * 24));

                        if (survey.participantCount > 5) {
                            statusBadges += `<span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-2 py-1"><i class="mdi mdi-fire"></i> Trend</span>`;
                        }
                        if (diffDays <= 7) {
                            statusBadges += `<span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1 ms-1"><i class="mdi mdi-new-box"></i> Yeni</span>`;
                        }

                        // 🔥 OKLAR SİLİNDİ
                        var btnHtml = "";
                        var participatedBadge = "";
                        if (survey.isParticipated) {
                            participatedBadge = `<div class="position-absolute" style="top: -10px; right: -10px; z-index: 10;"><span class="badge bg-success shadow" style="font-size:0.8rem; border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;"><i class="mdi mdi-check text-white" style="font-size: 1.2rem;"></i></span></div>`;
                            btnHtml = `<a href="/Home/UserResult/${survey.id}" class="btn btn-outline-success btn-block w-100 py-2 mt-3 font-weight-bold rounded-pill text-center">Sonuçları İncele</a>`;
                        } else {
                            btnHtml = `<button class="btn btn-gradient-primary btn-block w-100 py-2 mt-3 font-weight-bold rounded-pill text-center" onclick="solveSurvey('${survey.id}')">Anketi Çöz</button>`;
                        }

                        var card = `
                            <div class="col-md-4 mb-4 d-flex align-items-stretch">
                                <div class="modern-survey-card w-100 p-4 shadow-sm">
                                    ${participatedBadge}
                                    <div class="card-badge-container">
                                        <span class="badge badge-outline-primary rounded-pill px-3 py-1 font-weight-bold">${survey.categoryName}</span>
                                        ${statusBadges}
                                    </div>
                                    <h4 class="text-dark font-weight-bold mb-2 line-clamp-2" style="font-size: 1.15rem; line-height: 1.4;">${survey.title}</h4>
                                    <p class="text-muted mb-3 line-clamp-2" style="font-size: 0.85rem;">${desc}</p>
                                    <div class="text-muted small mb-4 font-weight-bold">
                                        <i class="mdi mdi-clock-outline me-1 text-primary"></i> ⏱ ${estTime} dk tahmin
                                    </div>
                                    <div class="card-footer-stats">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <div class="text-muted small font-weight-bold"><i class="mdi mdi-account-group text-primary"></i> 👥 ${survey.participantCount} Katılım</div>
                                            <div class="text-primary small font-weight-bold">%${compRate}</div>
                                        </div>
                                        <div class="mini-progress-bg mb-2 shadow-sm">
                                            <div class="mini-progress-fill" style="width: ${compRate}%;"></div>
                                        </div>
                                        ${btnHtml}
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(card);
                    });
                }
            });
        }

        function solveSurvey(id) {
            window.location.href = '/Home/SurveyDetail/' + id;
        }
    </script>
}