@{
    ViewData["Title"] = "Teşekkürler";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    .success-icon {
        width: 100px;
        height: 100px;
        background-color: #e8f9f4;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        animation: scaleUp 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .success-icon i {
            font-size: 50px;
            color: #1bcfb4;
        }

    @@keyframes scaleUp {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<div class="row justify-content-center text-center mt-5 mb-5">
    <div class="col-lg-6 col-md-8">
        <div class="card shadow-lg border-0 rounded" style="padding: 50px 30px;">
            <div class="card-body">
                <div class="success-icon shadow-sm">
                    <i class="mdi mdi-check-all"></i>
                </div>

                <h1 class="display-4 font-weight-bold text-dark mb-3">Harika!</h1>
                <h4 class="text-muted mb-4" style="line-height: 1.6;">
                    Ankete katıldığınız için teşekkür ederiz. Değerli geri bildirimleriniz başarıyla sistemimize kaydedildi.
                </h4>

                <div class="mt-5 d-flex justify-content-center gap-3">
                    <a href="/Home/Index" class="btn btn-gradient-primary btn-lg font-weight-bold px-4 shadow-sm">
                        <i class="mdi mdi-text-box-search-outline me-2"></i> Başka Anketlere Göz At
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>