@{
    ViewData["Title"] = "Anket Çöz";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    /* 🔥 AŞAMA 3.1 & 3.4: STEP SİSTEMİ VE ANİMASYONLAR */
    body { background-color: #f4f7fa; }
    body.dark-mode { background-color: #121212; }

    .survey-container { max-width: 800px; margin: 0 auto; margin-top: 40px; margin-bottom: 60px; }
    
    .question-step { 
        display: none; 
        animation: fadeInRight 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) forwards; 
    }
    .question-step.active { display: block; }
    
    @@keyframes fadeInRight { 
        from { opacity: 0; transform: translateX(30px); } 
        to { opacity: 1; transform: translateX(0); } 
    }

    /* 🔥 PROGRESS BAR (İlerleme Çubuğu) */
    .progress-wrapper { background: #e9ecef; border-radius: 10px; height: 8px; width: 100%; overflow: hidden; margin-top: 15px; }
    .progress-fill { background: linear-gradient(90deg, #b66dff, #4facfe); height: 100%; width: 0%; transition: width 0.5s ease-in-out; border-radius: 10px; }
    body.dark-mode .progress-wrapper { background: #333; }

    /* 🔥 SEÇENEK (OPTION) TASARIMLARI */
    .option-label {
        display: block;
        padding: 15px 20px;
        border: 2px solid #ebedf2;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 500;
        background: #fff;
    }
    .option-label:hover { border-color: #b66dff; background: rgba(182, 109, 255, 0.05); }
    
    /* Input (Radio/Checkbox) Gizli ama Tıklanabilir */
    .option-input { display: none; }
    .option-input:checked + .option-label {
        border-color: #b66dff;
        background: rgba(182, 109, 255, 0.1);
        color: #b66dff;
        box-shadow: 0 4px 10px rgba(182, 109, 255, 0.15);
    }

    body.dark-mode .option-label { background: #2c2c2c; border-color: #444; color: #e0e0e0; }
    body.dark-mode .option-input:checked + .option-label { background: rgba(182, 109, 255, 0.2); }

    /* 🔥 VALIDATION (HATA) ANİMASYONU - SHAKE */
    .shake-error {
        animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both;
        border-color: #ff4d4d !important;
    }
    .shake-error .option-label { border-color: #ff4d4d !important; background: rgba(255, 77, 77, 0.05); }
    
    @@keyframes shake {
        10%, 90% { transform: translate3d(-2px, 0, 0); }
        20%, 80% { transform: translate3d(2px, 0, 0); }
        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
        40%, 60% { transform: translate3d(4px, 0, 0); }
    }

    .inline-error { color: #ff4d4d; font-size: 0.85rem; font-weight: bold; margin-top: 10px; display: none; }
    /* 🔥 AŞAMA 7.2: STICKY ACTION BUTTON (Mobilde Alt Bar) */
    @@media (max-width: 768px) {
        .survey-container {
            margin-top: 10px;
            margin-bottom: 100px !important;
        }

            .survey-container .card {
                border-radius: 12px !important;
                border: none;
            }

        .option-label {
            min-height: 55px;
            display: flex;
            align-items: center;
            padding: 10px 15px;
            margin-bottom: 12px;
        }

        .card-footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: #ffffff !important;
            z-index: 9999;
            box-shadow: 0 -5px 25px rgba(0,0,0,0.1);
            border-radius: 20px 20px 0 0 !important;
            padding: 15px 20px !important;
            display: flex;
            justify-content: space-between;
        }

        body.dark-mode .card-footer {
            background: #1e1e1e !important;
            box-shadow: 0 -5px 25px rgba(0,0,0,0.5);
        }
    }
</style>

<div class="survey-container">
    <div class="card shadow-lg border-0 rounded-xl" style="border-radius: 20px; overflow: hidden;">
        
        <!-- ÜST KISIM (Başlık ve İlerleme) -->
        <div class="card-header bg-white border-bottom p-4 pt-5">
            <h2 class="font-weight-bold text-dark mb-2" id="surveyTitle">Yükleniyor...</h2>
            <p class="text-muted" id="surveyDesc"></p>
            
            <div class="d-flex justify-content-between mt-4">
                <span class="text-primary font-weight-bold" id="progressText">%0 Tamamlandı</span>
                <span class="text-muted font-weight-bold" id="stepText">Soru 1 / ?</span>
            </div>
            <div class="progress-wrapper"><div class="progress-fill" id="progressBar"></div></div>
        </div>

        <!-- ORTA KISIM (Soruların Geleceği Yer) -->
        <div class="card-body p-4 p-md-5" id="questionContainer" style="min-height: 350px;">
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        </div>

        <!-- ALT KISIM (Navigasyon Butonları) -->
        <div class="card-footer bg-light border-top p-4 d-flex justify-content-between align-items-center" id="surveyFooter">
            <button class="btn btn-outline-danger px-4 py-2 rounded-pill font-weight-bold me-2" onclick="window.location.href='/Home/Index'">
                <i class="mdi mdi-close-circle-outline me-1"></i> Çık
            </button>

            <button class="btn btn-outline-secondary px-4 py-2 rounded-pill font-weight-bold" id="btnPrev" style="display:none; transition: all 0.3s;">
                <i class="mdi mdi-arrow-left me-1"></i> Önceki
            </button>
            <button class="btn btn-gradient-primary px-5 py-2 rounded-pill font-weight-bold ms-auto" id="btnNext" style="display:none; transition: all 0.3s;">
                Sonraki <i class="mdi mdi-arrow-right ms-1"></i>
            </button>
            <button class="btn btn-success px-5 py-2 rounded-pill font-weight-bold ms-auto" id="btnSubmit" style="display:none; transition: all 0.3s;">
                <i class="mdi mdi-check-circle me-1"></i> Anketi Tamamla
            </button>
        </div>
        
    </div>
</div>

@section Scripts {
    <script>
        var surveyId = window.location.pathname.split('/').pop();
        var questionsData = [];
        var currentStep = 0;
        var answers = {};
                var currentToken = localStorage.getItem("token") || "guest";
        var draftKey = 'survey_draft_' + surveyId + '_' + currentToken.substring(currentToken.length - 15);

        $(document).ready(function () {

            var token = localStorage.getItem("token");
            if (!token) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Giriş Gerekli',
                    text: 'Anketi çözebilmek için lütfen önce giriş yapın veya kayıt olun.',
                    confirmButtonColor: '#b66dff',
                    confirmButtonText: 'Giriş Yap',
                    allowOutsideClick: false 
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = "/Auth/Login";
                    }
                });
                return; 
            }

            loadSurveyData();

            $("#btnNext").click(function () { nextStep(); });
            $("#btnPrev").click(function () { prevStep(); });
            $("#btnSubmit").click(function () { submitSurvey(); });

            $(document).on("change", ".option-input, .text-input", function() {
                saveDraft();
                $(this).closest(".question-step").removeClass("shake-error");
                $(this).closest(".question-step").find(".inline-error").slideUp();
            });
        });


        function getQType(q) {
             var t = q.questionType ? q.questionType.toString().toLowerCase() : "";

             if (t === "0" || t === "text" || t === "metin") return "Text";

             if (!q.options || q.options.length === 0) return "Text"; // Şık yoksa kesin yazıdır
             if (t.includes("checkbox") || t.includes("çoklu") || t === "2") return "Checkbox";

             return "Radio"; // Varsayılan şıklı soru
         }

        function loadSurveyData() {
             var token = localStorage.getItem("token");
             $.ajax({
                 url: `https://localhost:7283/api/survey/${surveyId}/detail`,
                 type: "GET",
                 headers: { "Authorization": "Bearer " + token },
                 success: function (data) {
                     $("#surveyTitle").text(data.title);
                     $("#surveyDesc").text(data.description);
                     questionsData = data.questions;

                     renderQuestions();
                     checkDraftAndStart();
                 },
                 error: function (xhr) {
                     var errorTitle = "Anket Bulunamadı";
                     var errorMessage = "Bu anket yayından kaldırılmış, süresi dolmuş veya henüz taslak aşamasında olabilir.";
                     var iconClass = "mdi-alert-circle-outline text-danger";

                     // 🔥 ZATEN ÇÖZÜLDÜ YAKALAYICI
                     if (xhr.status === 400 && xhr.responseJSON && xhr.responseJSON.errorCode === "ALREADY_SOLVED") {
                         errorTitle = "Zaten Çözdünüz! ✅";
                         errorMessage = "Harika! Bu anketi daha önce başarıyla tamamlamışsınız. Aynı ankete birden fazla kez katılamazsınız.";
                         iconClass = "mdi-check-decagram text-success";
                     }

                     $("#questionContainer").html(`
                         <div class="text-center py-5 fade-in-up">
                             <i class="mdi ${iconClass}" style="font-size: 5rem;"></i>
                             <h4 class="mt-3 font-weight-bold text-dark">${errorTitle}</h4>
                             <p class="text-muted">${errorMessage}</p>
                             <a href="/Home/Index" class="btn btn-gradient-primary rounded-pill mt-4 px-5 py-2 font-weight-bold shadow-sm">
                                 <i class="mdi mdi-arrow-left me-1"></i> Keşfetmeye Dön
                             </a>
                         </div>
                     `);

                     // Sayfadaki diğer elemanları temizle
                     $("#surveyTitle").text("İşlem Tamamlanamıyor");
                     $("#surveyDesc").text("");
                     $(".progress-wrapper").hide();
                     $("#surveyFooter").hide();
                 }
             });
         }

        function renderQuestions() {
            var container = $("#questionContainer");
            container.empty();

            $.each(questionsData, function (index, q) {
                var requiredBadge = q.isRequired ? `<span class="text-danger ms-1" title="Zorunlu Alan">*</span>` : ``;

                var html = `<div class="question-step" id="step_${index}" data-req="${q.isRequired}" data-qid="${q.id}">`;
                html += `<h3 class="font-weight-bold mb-4 line-height-base">${q.questionText} ${requiredBadge}</h3>`;

                html += `<div class="options-container">`;

                var safeType = getQType(q); // Akıllı kontrol

                if (safeType === "Text") {
                    html += `<textarea class="form-control bg-light border-1 rounded-lg text-input p-3" rows="4" placeholder="Cevabınızı buraya yazın..." name="q_${q.id}"></textarea>`;
                } else if (safeType === "Radio") {
                    $.each(q.options, function(i, opt) {
                        html += `
                            <div class="mb-3">
                                <input type="radio" class="option-input" name="q_${q.id}" id="opt_${opt.id}" value="${opt.id}">
                                <label class="option-label" for="opt_${opt.id}">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3" style="width:24px;height:24px;border:2px solid #b66dff;border-radius:50%;display:flex;align-items:center;justify-content:center;"><i class="mdi mdi-circle text-white" style="font-size:12px;"></i></div>
                                        ${opt.optionText}
                                    </div>
                                </label>
                            </div>
                        `;
                    });
                } else if (safeType === "Checkbox") {
                    $.each(q.options, function(i, opt) {
                        html += `
                            <div class="mb-3">
                                <input type="checkbox" class="option-input" name="q_${q.id}" id="opt_${opt.id}" value="${opt.id}">
                                <label class="option-label" for="opt_${opt.id}">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3" style="width:24px;height:24px;border:2px solid #b66dff;border-radius:4px;display:flex;align-items:center;justify-content:center;"><i class="mdi mdi-check text-white" style="font-size:16px;"></i></div>
                                        ${opt.optionText}
                                    </div>
                                </label>
                            </div>
                        `;
                    });
                }

                html += `</div>`;
                html += `<div class="inline-error"><i class="mdi mdi-alert-circle"></i> Lütfen bu soruyu cevaplayın.</div>`;
                html += `</div>`;

                container.append(html);
            });
        }

        function checkDraftAndStart() {
            var draft = localStorage.getItem(draftKey);
            if (draft) {
                Swal.fire({
                    title: 'Yarım Kalan Anket!',
                    text: "Bu anket için daha önce verdiğin cevaplar var. Kaldığın yerden devam etmek ister misin?",
                    icon: 'info',
                    showCancelButton: true,
                    confirmButtonColor: '#b66dff',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Evet, devam et',
                    cancelButtonText: 'Hayır, baştan başla'
                }).then((result) => {
                    if (result.isConfirmed) {
                        answers = JSON.parse(draft);
                        restoreAnswers();
                    } else {
                        localStorage.removeItem(draftKey);
                    }
                    showStep(0);
                });
            } else {
                showStep(0);
            }
        }

        function saveDraft() {
            extractCurrentAnswers();
            localStorage.setItem(draftKey, JSON.stringify(answers));
        }

        function restoreAnswers() {
            $.each(answers, function(qId, val) {
                var inputName = `q_${qId}`;
                var inputEle = $(`[name='${inputName}']`);

                if(inputEle.attr('type') === 'radio') {
                    $(`input[name='${inputName}'][value='${val}']`).prop('checked', true);
                } else if(inputEle.attr('type') === 'checkbox') {
                    $.each(val, function(i, v) { $(`input[name='${inputName}'][value='${v}']`).prop('checked', true); });
                } else {
                    inputEle.val(val);
                }
            });
        }

        function extractCurrentAnswers() {
            var currentQ = questionsData[currentStep];
            var inputName = `q_${currentQ.id}`;
            var type = getQType(currentQ);

            if (type === "Radio") {
                var val = $(`input[name='${inputName}']:checked`).val();
                if(val) answers[currentQ.id] = val;
            } else if (type === "Checkbox") {
                var vals = [];
                $(`input[name='${inputName}']:checked`).each(function() { vals.push($(this).val()); });
                if(vals.length > 0) answers[currentQ.id] = vals; else delete answers[currentQ.id];
            } else {
                var txt = $(`[name='${inputName}']`).val().trim();
                if(txt) answers[currentQ.id] = txt; else delete answers[currentQ.id];
            }
        }

        function showStep(index) {
            $(".question-step").removeClass("active");
            $(`#step_${index}`).addClass("active");
            currentStep = index;

            updateProgress();

            if (index === 0) { $("#btnPrev").hide(); } else { $("#btnPrev").fadeIn(); }

            if (index === questionsData.length - 1) {
                $("#btnNext").hide();
                $("#btnSubmit").fadeIn();
            } else {
                $("#btnNext").fadeIn();
                $("#btnSubmit").hide();
            }
        }

        function nextStep() {
            if (validateStep()) {
                extractCurrentAnswers();
                saveDraft();
                showStep(currentStep + 1);
            }
        }

        function prevStep() {
            extractCurrentAnswers();
            saveDraft();
            showStep(currentStep - 1);
        }

        function validateStep() {
            var stepDiv = $(`#step_${currentStep}`);
            var isRequired = stepDiv.attr("data-req") === "true";

            if (!isRequired) return true;

            var currentQ = questionsData[currentStep];
            var inputName = `q_${currentQ.id}`;
            var type = getQType(currentQ);
            var isValid = false;

            if (type === "Radio" && $(`input[name='${inputName}']:checked`).length > 0) isValid = true;
            if (type === "Checkbox" && $(`input[name='${inputName}']:checked`).length > 0) isValid = true;
            if (type === "Text" && $(`[name='${inputName}']`).val().trim() !== "") isValid = true;

            if (!isValid) {
                stepDiv.removeClass("shake-error");
                void stepDiv[0].offsetWidth;
                stepDiv.addClass("shake-error");
                stepDiv.find(".inline-error").slideDown();

                showErrorToast("Lütfen bu soruyu boş bırakmayın!");
                return false;
            }

            return true;
        }

        function updateProgress() {
            var total = questionsData.length;
            var percent = Math.round((currentStep / total) * 100);

            $("#stepText").text(`Soru ${currentStep + 1} / ${total}`);
            $("#progressText").text(`%${percent} Tamamlandı`);
            $("#progressBar").css("width", percent + "%");
        }

        function submitSurvey() {
            if (!validateStep()) return;
            extractCurrentAnswers();

            var token = localStorage.getItem("token");
            var btn = $("#btnSubmit");
            btn.prop('disabled', true).html('<i class="mdi mdi-loading mdi-spin"></i> Gönderiliyor...');

            var payload = {
                surveyId: parseInt(surveyId),
                answers: []
            };

            $.each(answers, function(qId, val) {
                if (Array.isArray(val)) {
                    $.each(val, function(i, v) { payload.answers.push({ questionId: parseInt(qId), selectedOptionId: parseInt(v), answerText: "" }); });
                } else if ($.isNumeric(val)) {
                    payload.answers.push({ questionId: parseInt(qId), selectedOptionId: parseInt(val), answerText: "" });
                } else {
                    payload.answers.push({ questionId: parseInt(qId), selectedOptionId: null, answerText: val });
                }
            });

            $.ajax({
                url: "https://localhost:7283/api/survey/submit",
                type: "POST",
                contentType: "application/json",
                headers: { "Authorization": "Bearer " + token },
                data: JSON.stringify(payload),
                success: function (res) {
                    localStorage.removeItem(draftKey);
                    Swal.fire({
                        icon: 'success',
                        title: 'Harika!',
                        text: 'Anket başarıyla gönderildi. Katılımınız için teşekkürler.',
                        confirmButtonColor: '#b66dff'
                    }).then(() => {
                        window.location.href = "/Home/Index";
                    });
                },
                error: function (xhr) {
                    btn.prop('disabled', false).html('<i class="mdi mdi-check-circle me-1"></i> Anketi Tamamla');
                    showErrorToast("Gönderim sırasında hata oluştu.");
                }
            });
        }
    </script>
}