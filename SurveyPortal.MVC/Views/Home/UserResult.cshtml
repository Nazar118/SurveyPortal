@{
    ViewData["Title"] = "Anket Sonuçları";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<style>
    body {
        background-color: #f4f7fa;
    }

        body.dark-mode {
            background-color: #121212;
        }

    .result-container {
        max-width: 900px;
        margin: 0 auto;
        margin-top: 40px;
        margin-bottom: 60px;
    }

    /* 🔥 INSIGHT KART TASARIMI */
    .insight-card {
        background: linear-gradient(135deg, rgba(182, 109, 255, 0.1) 0%, rgba(79, 172, 254, 0.1) 100%);
        border: 1px solid rgba(182, 109, 255, 0.2);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 30px;
    }

    body.dark-mode .insight-card {
        background: rgba(182, 109, 255, 0.05);
    }

    /* 🔥 PROGRESS BAR & WINNER HIGHLIGHT */
    .result-option {
        position: relative;
        background: #fff;
        border: 1px solid #ebedf2;
        border-radius: 12px;
        padding: 15px 20px;
        margin-bottom: 12px;
        overflow: hidden;
        z-index: 1;
    }

    body.dark-mode .result-option {
        background: #2c2c2c;
        border-color: #444;
        color: #e0e0e0;
    }

    /* Arka plan dolgusu (Animasyonlu) */
    .result-option-bg {
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        background: rgba(182, 109, 255, 0.1);
        z-index: -1;
        width: 0%;
        transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .result-option.winner {
        border-color: #b66dff;
    }

        .result-option.winner .result-option-bg {
            background: rgba(182, 109, 255, 0.2);
        }

    .option-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .option-text {
        font-weight: 600;
        font-size: 1.05rem;
    }

    .option-percent {
        font-weight: 800;
        font-size: 1.1rem;
        color: #b66dff;
    }

    /* Etiketler (👑 Winner & ✔ Your Choice) */
    .badge-winner {
        background: #ffd700;
        color: #856404;
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 6px;
        font-weight: bold;
        margin-left: 8px;
    }

    .badge-user-choice {
        background: #28a745;
        color: white;
        font-size: 0.75rem;
        padding: 4px 8px;
        border-radius: 6px;
        font-weight: bold;
        margin-left: 8px;
    }

    /* 🔥 WORD CLOUD TASARIMI */
    .word-cloud-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: center;
        align-items: center;
        padding: 20px;
        background: rgba(0,0,0,0.02);
        border-radius: 12px;
    }

    body.dark-mode .word-cloud-container {
        background: rgba(255,255,255,0.02);
    }

    .cloud-word {
        line-height: 1;
        transition: transform 0.3s;
    }

        .cloud-word:hover {
            transform: scale(1.1);
            cursor: default;
        }

</style>

<div class="result-container">
    <div class="card shadow-sm border-0 rounded-xl" style="border-radius: 20px;">

        <div class="card-header bg-white border-bottom p-4 pt-5 text-center">
            <div class="mb-3">
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 font-weight-bold">
                    <i class="mdi mdi-chart-donut"></i> Anket Sonuçları
                </span>
            </div>
            <h2 class="font-weight-bold text-dark mb-2" id="resTitle">Yükleniyor...</h2>
            <p class="text-muted" id="resDesc"></p>
            <div class="text-muted font-weight-bold mt-3">
                <i class="mdi mdi-account-group text-primary" style="font-size: 1.2rem;"></i> Toplam <span id="resTotal" class="text-dark">0</span> Katılımcı
            </div>
        </div>

        <div class="card-body p-4 p-md-5">
            <!-- İÇGÖRÜ (INSIGHTS) BÖLÜMÜ -->
            <div id="insightsContainer" style="display: none;">
                <div class="insight-card">
                    <h5 class="font-weight-bold text-primary mb-3"><i class="mdi mdi-lightbulb-on-outline"></i> Öne Çıkan İçgörüler</h5>
                    <ul class="mb-0 text-muted" id="insightsList" style="line-height: 1.8;"></ul>
                </div>
            </div>

            <!-- SORULAR VE ÇUBUKLAR -->
            <div id="resultsWrapper">
                <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
            </div>

            <!-- 🔥 ANA SAYFAYA DÖN BUTONU 🔥 -->
            <div class="text-center mt-5 pt-4 border-top">
                <a href="/Home/Index" class="btn btn-outline-primary rounded-pill px-5 py-2 font-weight-bold shadow-sm" style="transition: all 0.3s;">
                    <i class="mdi mdi-arrow-left me-2"></i> Keşfetmeye Geri Dön
                </a>
            </div>
        </div>

    </div>
</div>

<input type="hidden" id="hiddenSurveyId" value="@ViewBag.SurveyId" />

@section Scripts {
    <script>
        var surveyId = $("#hiddenSurveyId").val();

        $(document).ready(function () {
            loadResults();
        });

        function loadResults() {
            var token = localStorage.getItem("token");
            $.ajax({
                url: `https://localhost:7283/api/survey/${surveyId}/results`,
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    renderHeader(data);
                    renderInsights(data.insights);
                    renderQuestions(data.questions);
                },
                error: function () {
                    showErrorToast("Sonuçlar yüklenirken bir hata oluştu.");
                }
            });
        }

        function renderHeader(data) {
            $("#resTitle").text(data.title);
            $("#resDesc").text(data.description);
            $("#resTotal").text(data.totalParticipants);
        }

        function renderInsights(insights) {
            if (insights && insights.length > 0) {
                var list = $("#insightsList");
                list.empty();
                $.each(insights, function(i, text) {
                    list.append(`<li>${text}</li>`);
                });
                $("#insightsContainer").slideDown();
            }
        }

        function renderQuestions(questions) {
            var wrapper = $("#resultsWrapper");
            wrapper.empty();

            if (!questions || questions.length === 0) {
                wrapper.html('<div class="alert alert-info text-center">Bu ankete henüz katılım sağlanmamış.</div>');
                return;
            }

            $.each(questions, function (index, q) {
                var html = `<div class="mb-5 pb-3">`;
                html += `<h4 class="font-weight-bold mb-4">${index + 1}. ${q.questionText}</h4>`;

                if (q.questionType === "Text") {
                    // WORD CLOUD (Kelime Bulutu) OLUŞTURMA
                    html += generateWordCloud(q.textAnswers);
                } else {
                    // PROGRESS BARS (Seçenekler)
                    $.each(q.options, function(i, opt) {
                        var isWinner = opt.isWinner ? "winner" : "";
                        var winnerBadge = opt.isWinner ? `<span class="badge-winner">👑 Lider</span>` : "";
                        var userChoiceBadge = opt.isUserChoice ? `<span class="badge-user-choice"><i class="mdi mdi-check"></i> Sen Seçtin</span>` : "";

                        html += `
                            <div class="result-option ${isWinner}">
                                <div class="result-option-bg" data-width="${opt.percentage}%"></div>
                                <div class="option-meta">
                                    <div class="option-text text-dark">
                                        ${opt.optionText}
                                        ${winnerBadge}
                                        ${userChoiceBadge}
                                    </div>
                                    <div class="option-percent">${opt.percentage}% <span class="text-muted" style="font-size:0.8rem;font-weight:normal;">(${opt.count} oy)</span></div>
                                </div>
                            </div>
                        `;
                    });
                }

                html += `</div>`;
                wrapper.append(html);
            });

            // Sayfa yüklendikten az sonra animasyonları tetikle
            setTimeout(() => {
                $(".result-option-bg").each(function() {
                    $(this).css("width", $(this).attr("data-width"));
                });
            }, 100);
        }

        // 🔥 BASİT VE ŞIK BİR KELİME BULUTU (WORD CLOUD) ALGORİTMASI
        function generateWordCloud(sentences) {
            if (!sentences || sentences.length === 0) return `<div class="text-muted text-center py-3 bg-light rounded">Henüz yazılı cevap yok.</div>`;

            // Tüm cümleleri kelimelere böl, noktalama işaretlerini at, küçük harf yap
            var words = [];
            var stopWords = ["ve", "ile", "bir", "bu", "da", "de", "için", "çok", "daha", "gibi", "kadar"]; // Atılacak bağlaçlar

            $.each(sentences, function(i, sentence) {
                var cleaned = sentence.toLowerCase().replace(/[.,!?;:()]/g, '').split(' ');
                $.each(cleaned, function(j, w) {
                    if (w.length > 2 && !stopWords.includes(w)) words.push(w);
                });
            });

            // Frekans (Sıklık) hesapla
            var counts = {};
            $.each(words, function(i, w) { counts[w] = (counts[w] || 0) + 1; });

            // Sıklığa göre HTML üret (Büyüklük ve Renk ayarlaması)
            var cloudHtml = `<div class="word-cloud-container">`;
            var colors = ["#b66dff", "#4facfe", "#ff6b6b", "#43d39e", "#f3a683", "#2c3e50"];

            $.each(counts, function(word, count) {
                var fontSize = 1 + (count * 0.2); // En az 1rem, sıklığa göre büyür
                if (fontSize > 3) fontSize = 3; // Maksimum 3rem
                var color = colors[Math.floor(Math.random() * colors.length)];
                var weight = count > 1 ? "bold" : "normal";

                cloudHtml += `<span class="cloud-word" style="font-size: ${fontSize}rem; color: ${color}; font-weight: ${weight};" title="${count} kez kullanıldı">${word}</span>`;
            });
            cloudHtml += `</div>`;

            return cloudHtml;
        }
    </script>
}