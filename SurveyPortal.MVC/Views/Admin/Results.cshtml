@{
    ViewData["Title"] = "Anket Analizi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h3 class="page-title text-primary font-weight-bold" id="surveyTitle">
        <i class="mdi mdi-chart-pie me-2"></i> Analiz Yükleniyor...
    </h3>
    <a href="/Admin/SurveyList" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
</div>

<ul class="nav nav-pills nav-fill bg-white shadow-sm rounded mb-4" id="pills-tab" role="tablist" style="padding: 10px;">
    <li class="nav-item" role="presentation">
        <button class="nav-link active font-weight-bold" id="pills-grafik-tab" data-bs-toggle="pill" data-bs-target="#pills-grafik" type="button" role="tab">
            <i class="mdi mdi-chart-bar"></i> Genel İstatistikler
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link font-weight-bold" id="pills-kullanici-tab" data-bs-toggle="pill" data-bs-target="#pills-kullanici" type="button" role="tab">
            <i class="mdi mdi-account-details"></i> Katılımcı Yanıtları
        </button>
    </li>
</ul>

<div class="tab-content" id="pills-tabContent">
    <div class="tab-pane fade show active" id="pills-grafik" role="tabpanel">
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-info d-flex justify-content-between align-items-center">
                    <span class="font-weight-bold"><i class="mdi mdi-account-group"></i> Toplam Katılımcı Sayısı:</span>
                    <span class="badge badge-info" id="totalParticipants" style="font-size: 1rem;">0</span>
                </div>
            </div>
        </div>

        <div class="row" id="chartsContainer">
            <div class="col-12 text-center py-5" id="loadingSpinner">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="text-muted mt-2">Veriler analiz ediliyor...</p>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="pills-kullanici" role="tabpanel">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <!-- 🔥 EXCEL BUTONUNU BURAYA YERLEŞTİRDİM 🔥 -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="card-title m-0">Kim Ne Cevap Verdi?</h4>
                    <button class="btn btn-sm btn-success font-weight-bold shadow-sm" onclick="exportToCSV()">
                        <i class="mdi mdi-file-excel"></i> Excel / CSV İndir
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>Katılımcı / Kullanıcı Adı</th>
                                <th>Katılım Tarihi</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="userResponsesTable">
                            <tr>
                                <td colspan="4" class="text-center text-muted">Kullanıcı verileri yükleniyor...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="hiddenSurveyId" value="@ViewBag.SurveyId" />

<div class="modal fade" id="userAnswersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title font-weight-bold" id="modalUserName">
                    <i class="mdi mdi-account-circle me-2"></i> Kullanıcı Yanıtları
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body bg-light p-4">
                <ul class="list-group list-group-flush rounded shadow-sm" id="modalAnswersList"></ul>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        var currentSurveyId = $("#hiddenSurveyId").val();
        var globalUserData = []; // 🔥 EKSİK OLAN DEĞİŞKENİ BURAYA EKLEDİM

        $(document).ready(function () {
            loadResults();

            $('#pills-kullanici-tab').on('shown.bs.tab', function () {
                loadUserSpecificResponses();
            });
        });

        function loadResults() {
            $.ajax({
                url: "https://localhost:7283/api/result/" + currentSurveyId,
                type: "GET",
                success: function (res) {
                    $("#loadingSpinner").remove();
                    $("#surveyTitle").html(`<i class="mdi mdi-chart-pie me-2"></i> ${res.surveyTitle} - Analiz`);
                    $("#totalParticipants").text(res.totalParticipants);

                    var container = $("#chartsContainer");
                    if (res.questions.length === 0) {
                        container.html('<div class="col-12"><div class="alert alert-warning text-center">Henüz veri yok.</div></div>');
                        return;
                    }

                    $.each(res.questions, function (index, q) {
                        if (q.questionType === 0) {
                             var textHtml = `
                                <div class="col-md-6 grid-margin stretch-card mb-3">
                                    <div class="card shadow-sm border-1 border-light w-100">
                                        <div class="card-body p-3">
                                            <p class="font-weight-bold text-dark mb-3" style="font-size: 1rem;">${index + 1}. ${q.questionText} <span class="badge bg-info float-end">${q.totalAnswers} Yanıt</span></p>
                                            <div class="alert alert-info py-2 text-sm border-0 bg-light text-dark">
                                                <i class="mdi mdi-format-align-left text-info me-2"></i> Yanıtları <b>Katılımcı Yanıtları</b> sekmesinden inceleyebilirsiniz.
                                            </div>
                                        </div>
                                    </div>
                                </div>`;
                             container.append(textHtml);
                        }
                        else if (q.options && q.options.length > 0) {
                            var maxVotes = Math.max(...q.options.map(o => o.voteCount));
                            var listHtml = '<div class="mt-2">';

                            q.options.forEach(opt => {
                                var isWinner = (opt.voteCount === maxVotes && maxVotes > 0);

                                var fillBg = isWinner ? 'rgba(27, 207, 180, 0.2)' : 'rgba(182, 109, 255, 0.1)';
                                var iconHtml = isWinner ? '<i class="mdi mdi-crown text-warning me-2" style="font-size: 1.1rem;"></i>' : '<span class="me-3"></span>';
                                var borderClass = isWinner ? 'border-success' : 'border-light';

                                listHtml += `
                                    <div class="position-relative mb-2 border ${borderClass} rounded shadow-sm" style="background-color: #fdfdfd; overflow: hidden;">
                                        <div class="progress-fill" data-width="${opt.percentage}%" style="position: absolute; top: 0; left: 0; height: 100%; width: 0%; background-color: ${fillBg}; transition: width 1.2s ease-out;"></div>
                                        <div class="position-relative d-flex justify-content-between align-items-center py-2 px-3" style="z-index: 2;">
                                            <div class="d-flex align-items-center pe-2">
                                                ${iconHtml}
                                                <span class="text-dark font-weight-bold" style="font-size: 0.95rem;">${opt.optionText}</span>
                                            </div>
                                            <div class="d-flex align-items-center text-end" style="white-space: nowrap;">
                                                <span class="text-muted me-2" style="font-size: 0.8rem;">${opt.voteCount} Oy</span>
                                                <span class="text-dark font-weight-bold" style="font-size: 1rem;">%${opt.percentage}</span>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            });
                            listHtml += '</div>';

                            var cardHtml = `
                                <div class="col-md-6 grid-margin stretch-card mb-3">
                                    <div class="card shadow-sm border-1 border-light w-100">
                                        <div class="card-body p-3">
                                            <p class="font-weight-bold text-dark mb-2" style="font-size: 1rem;">${index + 1}. ${q.questionText} <span class="badge bg-primary float-end">${q.totalAnswers} Yanıt</span></p>
                                            ${listHtml}
                                        </div>
                                    </div>
                                </div>`;
                            container.append(cardHtml);
                        }
                    });

                    setTimeout(function() {
                        $(".progress-fill").each(function() {
                            $(this).css("width", $(this).attr("data-width"));
                        });
                    }, 100);

                },
                error: function () {
                    $("#chartsContainer").html('<div class="col-12"><div class="alert alert-danger text-center">Yüklenirken hata oluştu.</div></div>');
                }
            });
        }

        function loadUserSpecificResponses() {
             var tbody = $("#userResponsesTable");
             tbody.html('<tr><td colspan="4" class="text-center"><div class="spinner-border text-info spinner-border-sm"></div> Yükleniyor...</td></tr>');

             $.ajax({
                 url: "https://localhost:7283/api/result/users/" + currentSurveyId,
                 type: "GET",
                 success: function (data) {
                     globalUserData = data; // 🔥 DATA'YI EXCEL İÇİN KAYDETTİĞİMİZ YER 🔥
                     tbody.empty();

                     if(data.length === 0) {
                         tbody.append('<tr><td colspan="4" class="text-center text-muted">Bu anketi henüz kimse çözmemiş.</td></tr>');
                         return;
                     }

                     $.each(data, function(i, userResult) {
                         tbody.append(`
                             <tr class="bg-white">
                                 <td class="font-weight-bold"><i class="mdi mdi-account-circle text-primary me-2"></i> ${userResult.userName}</td>
                                 <td>${new Date(userResult.submissionDate).toLocaleDateString("tr-TR")}</td>
                                 <td><label class="badge bg-success text-white">Tamamladı</label></td>
                                 <td>
                                     <button class="btn btn-sm btn-outline-primary shadow-sm" onclick="toggleAnswers('${userResult.userId}')">
                                         <i class="mdi mdi-chevron-down"></i> Yanıtları Aç
                                     </button>
                                 </td>
                             </tr>
                         `);

                         var answersHtml = '<ul class="list-group list-group-flush mb-0">';
                         $.each(userResult.answers, function(j, ans) {
                             var ansText = ans.answer ? ans.answer : '<span class="text-muted fst-italic">Cevap verilmemiş</span>';
                             answersHtml += `
                                 <li class="list-group-item bg-transparent px-0 py-2 border-0 mb-1">
                                     <span class="font-weight-bold text-dark d-block" style="font-size:0.9rem;">${j+1}. ${ans.question}</span>
                                     <span class="text-primary mt-1 d-block"><i class="mdi mdi-subdirectory-arrow-right"></i> ${ansText}</span>
                                 </li>
                             `;
                         });
                         answersHtml += '</ul>';

                         tbody.append(`
                             <tr id="tr_detail_${userResult.userId}" style="display: none; background-color: #fafbfc;">
                                 <td colspan="4" class="p-0 border-0">
                                     <div id="div_detail_${userResult.userId}" class="p-4 border-start border-4 border-primary shadow-inner" style="display: none;">
                                         <h6 class="font-weight-bold text-muted mb-3"><i class="mdi mdi-format-list-bulleted"></i> ${userResult.userName} kişisinin yanıtları:</h6>
                                         ${answersHtml}
                                     </div>
                                 </td>
                             </tr>
                         `);
                     });
                 },
                 error: function () {
                     tbody.html('<tr><td colspan="4" class="text-center text-danger">Bağlantı hatası: Kullanıcı verileri çekilemedi!</td></tr>');
                 }
             });
        }

        function toggleAnswers(userId) {
            var tr = $(`#tr_detail_${userId}`);
            var div = $(`#div_detail_${userId}`);

            if (tr.is(':visible')) {
                div.slideUp(300, function() { tr.hide(); });
            } else {
                tr.show();
                div.slideDown(300);
            }
        }

        function exportToCSV() {
            if (!globalUserData || globalUserData.length === 0) {
                Swal.fire('Uyarı', 'İndirilecek yanıt bulunmuyor!', 'warning');
                return;
            }

            var csvContent = "\uFEFF";
            csvContent += "Kullanici Adi,Katilim Tarihi,Soru,Verilen Cevap\n";

            globalUserData.forEach(function(user) {
                var userName = user.userName.replace(/,/g, " ");
                var date = new Date(user.submissionDate).toLocaleDateString("tr-TR");

                user.answers.forEach(function(ans) {
                    var q = ans.question ? ans.question.replace(/,/g, " ") : "";
                    var a = ans.answer ? ans.answer.replace(/,/g, " ") : "Cevap verilmemiş";
                    csvContent += `${userName},${date},${q},${a}\n`;
                });
            });

            var blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            var url = URL.createObjectURL(blob);
            var link = document.createElement("a");
            link.setAttribute("href", url);
            link.setAttribute("download", "Anket_Sonuclari.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    </script>
}