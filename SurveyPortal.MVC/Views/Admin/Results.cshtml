@{
    ViewData["Title"] = "Anket Sonuçları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h3 class="page-title text-primary font-weight-bold" id="surveyTitle">
        <i class="mdi mdi-chart-pie me-2"></i> Sonuçlar Yükleniyor...
    </h3>
    <a href="/Admin/Index" class="btn btn-outline-secondary btn-sm">Geri Dön</a>
</div>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card bg-gradient-info text-white shadow-sm border-0">
            <div class="card-body text-center py-3">
                <h4 class="m-0"><i class="mdi mdi-account-group"></i> Toplam Katılım: <span id="totalParticipants" class="font-weight-bold">0</span> Kişi</h4>
            </div>
        </div>
    </div>
</div>

<div class="row" id="chartsContainer">
    <div class="col-12 text-center py-5" id="loadingSpinner">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Veriler analiz ediliyor...</p>
    </div>
</div>

<input type="hidden" id="hiddenSurveyId" value="@ViewBag.SurveyId" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        var currentSurveyId = $("#hiddenSurveyId").val();

        $(document).ready(function () {
            loadResults();
        });

        function loadResults() {
            $.ajax({
                url: "https://localhost:7283/api/result/" + currentSurveyId,
                type: "GET",
                success: function (res) {
                    $("#loadingSpinner").remove();
                    $("#surveyTitle").html(`<i class="mdi mdi-chart-pie me-2"></i> ${res.surveyTitle} - Analiz`);

                    // 6.5 EXTRA: Toplam Katılım Gösterimi
                    $("#totalParticipants").text(res.totalParticipants);

                    var container = $("#chartsContainer");

                    if (res.questions.length === 0) {
                        container.html('<div class="col-12"><div class="alert alert-warning text-center">Bu ankete henüz yanıt verilmemiş veya soru eklenmemiş.</div></div>');
                        return;
                    }

                    $.each(res.questions, function (index, q) {
                        var canvasId = `chart_q_${q.questionId}`;

                        // Her soru için standart kart iskeletini oluşturuyoruz
                        var cardHtml = `
                            <div class="col-md-6 grid-margin stretch-card">
                                <div class="card shadow-sm border-0 w-100">
                                    <div class="card-body">
                                        <h5 class="card-title text-dark font-weight-bold mb-4">${index + 1}. ${q.questionText}</h5>
                                        <p class="text-muted small">Bu soruya ${q.totalAnswers} yanıt verilmiş.</p>

                                        <div style="position: relative; height:250px; width:100%">
                                            <canvas id="${canvasId}"></canvas>
                                        </div>

                                        <!-- En popüler cevap veya metin yanıtları buraya gelecek -->
                                        <div id="extra_info_${q.questionId}" class="mt-3"></div>
                                    </div>
                                </div>
                            </div>
                        `;
                        container.append(cardHtml);

                        // EĞER SORU ŞIKLIYSA (Tekli veya Çoklu Seçim)
                        if (q.options && q.options.length > 0) {
                            var labels = q.options.map(o => o.optionText);
                            var dataPoints = q.options.map(o => o.voteCount);
                            var colors = ['#b66dff', '#4facfe', '#00f2fe', '#f83600', '#f9d423', '#1d976c'];

                            // 6.5 EXTRA: En çok seçilen cevabı bul ve karta ekle
                            var maxVotes = Math.max(...dataPoints);
                            if (maxVotes > 0) {
                                var topOption = q.options.find(o => o.voteCount === maxVotes);
                                $(`#extra_info_${q.questionId}`).html(`
                                    <div class="alert alert-success py-2 mb-0 d-flex justify-content-between align-items-center">
                                        <span><i class="mdi mdi-star text-warning"></i> <strong>En popüler:</strong> ${topOption.optionText}</span>
                                        <span class="badge bg-white text-success border border-success">${topOption.voteCount} Oy</span>
                                    </div>
                                `);
                            }

                            var isHorizontal = (q.questionType === 2);

                            var ctx = document.getElementById(canvasId).getContext('2d');
                            new Chart(ctx, {
                                type: 'bar', 
                                data: {
                                    labels: labels,
                                    datasets: [{
                                        label: 'Oy Sayısı',
                                        data: dataPoints,
                                        backgroundColor: colors.slice(0, labels.length),
                                        borderRadius: 4
                                    }]
                                },
                                options: {
                                    indexAxis: isHorizontal ? 'y' : 'x', 
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: { legend: { display: false } },
                                    scales: {
                                        y: { beginAtZero: true, ticks: { stepSize: 1 } },
                                        x: { beginAtZero: true, ticks: { stepSize: 1 } }
                                    }
                                }
                            });
                        }
                        else {
                            $(`#${canvasId}`).parent().remove(); 

                            var textHtml = '<ul class="list-group list-group-flush" style="max-height: 200px; overflow-y: auto;">';

                            if (q.textAnswers && q.textAnswers.length > 0) {
                                $.each(q.textAnswers, function(i, txt) {
                                    textHtml += `<li class="list-group-item bg-light mb-1 rounded text-sm"><i class="mdi mdi-comment-text-outline text-info"></i> ${txt}</li>`;
                                });
                            } else {
                                textHtml += '<li class="list-group-item text-muted">Bu soru için metin yanıtı bulunmuyor.</li>';
                            }

                            textHtml += '</ul>';
                            $(`#extra_info_${q.questionId}`).html(textHtml);
                        }
                    });
                },
                error: function (xhr) {
                    $("#loadingSpinner").html('<div class="alert alert-danger text-center">Sonuçlar yüklenirken bir hata oluştu.</div>');
                }
            });
        }
    </script>
}