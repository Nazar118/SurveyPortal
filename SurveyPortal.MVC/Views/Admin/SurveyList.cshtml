@{
    ViewData["Title"] = "Anket Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-format-list-bulleted"></i>
        </span> Anket Listesi
    </h3>
</div>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="card-title m-0">Kayıtlı Anketler</h4>
                    <button class="btn btn-gradient-success btn-sm font-weight-bold" data-bs-toggle="modal" data-bs-target="#addSurveyModal">
                        <i class="mdi mdi-plus"></i> Yeni Anket Ekle
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr class="bg-light">
                                <th>#</th>
                                <th>Anket Başlığı</th>
                                <th>Açıklama</th>
                                <th>Bitiş Tarihi</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="surveyTableBody">
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                                    Veriler yükleniyor...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- YENİ ANKET EKLEME MODALI -->
<div class="modal fade" id="addSurveyModal" role="dialog" aria-labelledby="addSurveyModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-gradient-success text-white">
                <h5 class="modal-title" id="addSurveyModalLabel">Yeni Anket Oluştur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addSurveyForm">
                    <div class="form-group mb-3">
                        <label for="surveyTitle" class="font-weight-bold">Anket Başlığı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" id="surveyTitle" placeholder="Örn: Müşteri Memnuniyeti Anketi" required>
                    </div>
                    <div class="form-group mb-3">
                        <label for="surveyDescription" class="font-weight-bold">Açıklama</label>
                        <textarea class="form-control" id="surveyDescription" rows="3" placeholder="Anketin amacı..."></textarea>
                    </div>
                    <div class="form-group mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label for="categoryId" class="font-weight-bold m-0">Kategori <span class="text-danger">*</span></label>
                            <a href="javascript:void(0);" id="btnAddNewCategory" class="text-success font-weight-bold text-decoration-none">
                                <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                            </a>
                        </div>
                        <select class="form-control form-control-lg" id="categoryId" required>
                            <option value="">Kategoriler Yükleniyor...</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label for="surveyEndDate" class="font-weight-bold">Bitiş Tarihi <small class="text-muted">(İsteğe Bağlı)</small></label>
                        <input type="date" class="form-control form-control-lg" id="surveyEndDate">
                    </div>
                    <!-- 🔥 Yeni Eklenen anket her zaman DRAFT olacağı için Checkbox kaldırıldı -->
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-gradient-success" id="btnSaveSurvey">Kaydet ve Oluştur</button>
            </div>
        </div>
    </div>
</div>

<!-- DÜZENLEME MODALI -->
<div class="modal fade" id="editSurveyModal" role="dialog" aria-labelledby="editSurveyModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-gradient-primary text-white">
                <h5 class="modal-title" id="editSurveyModalLabel">Anketi Düzenle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editSurveyForm">
                    <input type="hidden" id="editSurveyId">
                    <div class="form-group mb-3">
                        <label for="editSurveyTitle" class="font-weight-bold">Anket Başlığı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" id="editSurveyTitle" required>
                    </div>
                    <div class="form-group mb-3">
                        <label for="editSurveyDescription" class="font-weight-bold">Açıklama</label>
                        <textarea class="form-control" id="editSurveyDescription" rows="3"></textarea>
                    </div>
                    <div class="form-group mb-3">
                        <label for="editCategoryId" class="font-weight-bold">Kategori <span class="text-danger">*</span></label>
                        <select class="form-control form-control-lg" id="editCategoryId" required>
                            <option value="">Kategoriler Yükleniyor...</option>
                        </select>
                    </div>
                    <div class="form-group mb-3">
                        <label for="editSurveyEndDate" class="font-weight-bold">Bitiş Tarihi <small class="text-muted">(İsteğe Bağlı)</small></label>
                        <input type="date" class="form-control form-control-lg" id="editSurveyEndDate">
                    </div>
                    <!-- 🔥 YENİ: Checkbox yerine STATÜ Seçimi -->
                    <div class="form-group mb-3">
                        <label for="editSurveyStatus" class="font-weight-bold">Anket Durumu</label>
                        <select class="form-control form-control-lg" id="editSurveyStatus" required>
                            <option value="Draft">Taslak (Hazırlanıyor)</option>
                            <option value="Active">Aktif (Yayında)</option>
                            <option value="Closed">Kapalı (Süresi Doldu)</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-gradient-primary" id="btnUpdateSurvey">Değişiklikleri Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadSurveys();
            loadCategories();
        });

        // 1. KATEGORİLERİ YÜKLE
        function loadCategories() {
            $.ajax({
                url: "https://localhost:7283/api/category",
                type: "GET",
                success: function (categories) {
                    var dropdownAdd = $("#categoryId");
                    var dropdownEdit = $("#editCategoryId");

                    dropdownAdd.empty().append('<option value="">Lütfen Bir Kategori Seçin</option>');
                    dropdownEdit.empty().append('<option value="">Lütfen Bir Kategori Seçin</option>');

                    $.each(categories, function (index, category) {
                        var option = '<option value="' + category.id + '">' + category.name + '</option>';
                        dropdownAdd.append(option);
                        dropdownEdit.append(option);
                    });
                }
            });
        }

        // 2. ANKETLERİ YÜKLEME FONKSİYONU
        function loadSurveys() {
            $.ajax({
                url: "https://localhost:7283/api/survey",
                type: "GET",
                success: function (data) {
                    var tbody = $("#surveyTableBody");
                    tbody.empty();

                    if (data.length === 0) {
                        tbody.append('<tr><td colspan="6" class="text-center text-muted">Henüz hiç anket bulunmuyor.</td></tr>');
                        return;
                    }

                    $.each(data, function (index, survey) {
                        var description = survey.description ? survey.description.substring(0, 30) + (survey.description.length > 30 ? "..." : "") : "-";
                        var endDateText = survey.endDate ? new Date(survey.endDate).toLocaleDateString("tr-TR") : '<span class="text-muted fst-italic">Süresiz</span>';

                        // 🔥 1.4 UI ROZET GÜNCELLEMESİ (Draft=Sarı, Active=Yeşil, Closed=Kırmızı)
                        var statusBadge = "";
                        if (survey.status === "Draft") {
                            statusBadge = '<label class="badge bg-warning text-dark">Taslak</label>';
                        } else if (survey.status === "Active") {
                            statusBadge = '<label class="badge bg-success text-white">Yayında</label>';
                        } else if (survey.status === "Closed") {
                            statusBadge = '<label class="badge bg-danger text-white">Kapalı</label>';
                        }

                        var row = `
                            <tr>
                                <td>${index + 1}</td>
                                <td class="font-weight-bold">${survey.title || 'İsimsiz Anket'}</td>
                                <td><small class="text-muted">${description}</small></td>
                                <td>${endDateText}</td>
                                <td>${statusBadge}</td>
                                <td>
                                    <a href="/Admin/Questions/${survey.id}" class="btn btn-sm btn-info btn-icon-text text-white">
                                       <i class="mdi mdi-eye btn-icon-prepend"></i> Sorular
                                    </a>
                                    <button onclick="openEditModal('${survey.id}')" class="btn btn-sm btn-primary btn-icon-text text-white">
                                        <i class="mdi mdi-pencil btn-icon-prepend"></i> Düzenle
                                    </button>
                                    <a href="/Admin/Results/${survey.id}" class="btn btn-sm btn-warning btn-icon-text text-dark">
                                       <i class="mdi mdi-chart-pie btn-icon-prepend"></i> Sonuçlar
                                    </a>
                                    <button onclick="deleteSurvey('${survey.id}')" class="btn btn-sm btn-danger btn-icon-text">
                                        <i class="mdi mdi-delete btn-icon-prepend"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                }
            });
        }

        // 3. ANKET SİLME
        function deleteSurvey(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu anketi silerseniz içindeki sorular da gidebilir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#b66dff',
                confirmButtonText: 'Evet, Sil!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "https://localhost:7283/api/survey/" + id,
                        type: "DELETE",
                        success: function () {
                            Swal.fire({ icon: 'success', title: 'Silindi!', timer: 1500, showConfirmButton: false });
                            loadSurveys();
                        }
                    });
                }
            });
        }

        // 4. YENİ ANKET KAYDETME
        $("#btnSaveSurvey").click(function () {
            var titleInput = $("#surveyTitle").val();
            var descriptionInput = $("#surveyDescription").val();
            var categoryIdInput = $("#categoryId").val();
            var endDateInput = $("#surveyEndDate").val();

            if (!titleInput || !categoryIdInput) {
                Swal.fire('Uyarı', 'Lütfen Başlık ve Kategori alanlarını doldurunuz!', 'warning');
                return;
            }

            var surveyData = {
                title: titleInput,
                description: descriptionInput,
                categoryId: parseInt(categoryIdInput),
                status: "Draft", // 🔥 Yeni eklenen her anket taslaktır
                endDate: endDateInput ? endDateInput : null,
                isAnonymous: false
            };

            $.ajax({
                url: "https://localhost:7283/api/survey",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(surveyData),
                success: function () {
                    $("#addSurveyModal").modal('hide');
                    $("#addSurveyForm")[0].reset();
                    Swal.fire({ icon: 'success', title: 'Harika!', timer: 1500, showConfirmButton: false });
                    loadSurveys();
                }
            });
        });

        // Kategori Ekleme Popup'ı (Değişmedi)
        $("#btnAddNewCategory").click(function () {
            Swal.fire({
                title: 'Yeni Kategori Ekle', input: 'text', showCancelButton: true,
                confirmButtonColor: '#1bcfb4', cancelButtonColor: '#d33', confirmButtonText: 'Kaydet',
                target: document.getElementById('addSurveyModal'), customClass: { container: 'my-swal-container' }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "https://localhost:7283/api/category", type: "POST", contentType: "application/json",
                        data: JSON.stringify({ name: result.value }),
                        success: function () {
                            Swal.fire({ icon: 'success', title: 'Eklendi!', timer: 1500, showConfirmButton: false, target: document.getElementById('addSurveyModal'), customClass: { container: 'my-swal-container' } });
                            loadCategories();
                        }
                    });
                }
            });
        });

        var currentEditingSurvey = null;

        // 5. DÜZENLEME PENCERESİNİ AÇ
        function openEditModal(id) {
            $.ajax({
                url: "https://localhost:7283/api/survey/" + id,
                type: "GET",
                success: function (survey) {
                    currentEditingSurvey = survey;

                    $("#editSurveyId").val(survey.id);
                    $("#editSurveyTitle").val(survey.title);
                    $("#editSurveyDescription").val(survey.description);
                    $("#editCategoryId").val(survey.categoryId);

                    $("#editSurveyStatus").val(survey.status);

                    if (survey.endDate) {
                        var dateObj = new Date(survey.endDate);
                        var formattedDate = dateObj.toISOString().split('T')[0];
                        $("#editSurveyEndDate").val(formattedDate);
                    } else {
                        $("#editSurveyEndDate").val("");
                    }

                    $("#editSurveyModal").modal('show');
                }
            });
        }

        $("#btnUpdateSurvey").click(function () {
            if (!$("#editSurveyTitle").val() || !$("#editCategoryId").val()) {
                Swal.fire('Uyarı', 'Başlık ve Kategori boş bırakılamaz!', 'warning');
                return;
            }

            var newEndDate = $("#editSurveyEndDate").val();

            var updateData = {
                id: currentEditingSurvey.id,
                title: $("#editSurveyTitle").val(),
                description: $("#editSurveyDescription").val(),
                categoryId: parseInt($("#editCategoryId").val()),
                status: $("#editSurveyStatus").val(), 
                endDate: newEndDate ? newEndDate : null,
                createdDate: currentEditingSurvey.createdDate,
                isAnonymous: currentEditingSurvey.isAnonymous
            };

            $.ajax({
                url: "https://localhost:7283/api/survey/" + currentEditingSurvey.id,
                type: "PUT",
                contentType: "application/json",
                data: JSON.stringify(updateData),
                success: function () {
                    $("#editSurveyModal").modal('hide');
                    Swal.fire({ icon: 'success', title: 'Güncellendi!', timer: 1500, showConfirmButton: false });
                    loadSurveys();
                },
                error: function () {
                    Swal.fire('Hata!', 'Güncelleme sırasında bir sorun oluştu.', 'error');
                }
            });
        });
    </script>
}