@{
    ViewData["Title"] = "Anket Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-format-list-bulleted"></i>
        </span> Anket Listesi
    </h3>
</div>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="card-title m-0">Kayıtlı Anketler</h4>
                    <button class="btn btn-gradient-success btn-sm font-weight-bold" data-bs-toggle="modal" data-bs-target="#addSurveyModal">
                        <i class="mdi mdi-plus"></i> Yeni Anket Ekle
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr class="bg-light">
                                <th>#</th>
                                <th>Anket Başlığı</th>
                                <th>Açıklama</th>
                                <th>Oluşturulma Tarihi</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="surveyTableBody">
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                                    Veriler yükleniyor...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addSurveyModal" role="dialog" aria-labelledby="addSurveyModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-gradient-success text-white">
                <h5 class="modal-title" id="addSurveyModalLabel">Yeni Anket Oluştur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addSurveyForm">
                    <div class="form-group mb-3">
                        <label for="surveyTitle" class="font-weight-bold">Anket Başlığı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-lg" id="surveyTitle" placeholder="Örn: Müşteri Memnuniyeti Anketi" required>
                    </div>
                    <div class="form-group mb-3">
                        <label for="surveyDescription" class="font-weight-bold">Açıklama</label>
                        <textarea class="form-control" id="surveyDescription" rows="3" placeholder="Anketin amacı..."></textarea>
                    </div>
                    <div class="form-group mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label for="categoryId" class="font-weight-bold m-0">Kategori <span class="text-danger">*</span></label>

                            <a href="javascript:void(0);" id="btnAddNewCategory" class="text-success font-weight-bold text-decoration-none">
                                <i class="mdi mdi-plus-circle"></i> Yeni Ekle
                            </a>
                        </div>
                        <select class="form-control form-control-lg" id="categoryId" required>
                            <option value="">Kategoriler Yükleniyor...</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-gradient-success" id="btnSaveSurvey">Kaydet ve Oluştur</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadSurveys();
            loadCategories();
        });

        // 1. KATEGORİLERİ YÜKLE
        function loadCategories() {
            $.ajax({
                url: "https://localhost:7283/api/category",
                type: "GET",
                success: function (categories) {
                    var dropdown = $("#categoryId");
                    dropdown.empty();
                    dropdown.append('<option value="">Lütfen Bir Kategori Seçin</option>');

                    $.each(categories, function (index, category) {
                        dropdown.append('<option value="' + category.id + '">' + category.name + '</option>');
                    });
                },
                error: function (xhr) {
                    console.error("Kategoriler yüklenemedi", xhr);
                    $("#categoryId").html('<option value="">Kategoriler çekilemedi!</option>');
                }
            });
        }

        // 2. EKSİK OLAN ANKETLERİ YÜKLEME FONKSİYONU (Yeniden Eklendi)
        function loadSurveys() {
            $.ajax({
                url: "https://localhost:7283/api/survey",
                type: "GET",
                success: function (data) {
                    var tbody = $("#surveyTableBody");
                    tbody.empty();

                    if (data.length === 0) {
                        tbody.append('<tr><td colspan="5" class="text-center text-muted">Henüz hiç anket bulunmuyor.</td></tr>');
                        return;
                    }

                    $.each(data, function (index, survey) {
                        var date = survey.createdDate ? new Date(survey.createdDate).toLocaleDateString("tr-TR") : "-";
                        var description = survey.description ? survey.description.substring(0, 30) + (survey.description.length > 30 ? "..." : "") : "-";

                        var row = `
                            <tr>
                                <td>${index + 1}</td>
                                <td class="font-weight-bold">${survey.title || 'İsimsiz Anket'}</td>
                                <td><small class="text-muted">${description}</small></td>
                                <td>${date}</td>
                                <td>
                                    <a href="/Admin/Questions/${survey.id}" class="btn btn-sm btn-info btn-icon-text">
                                       <i class="mdi mdi-eye btn-icon-prepend"></i> Sorular
                                    </a>

                                    <a href="/Admin/Results/${survey.id}" class="btn btn-sm btn-warning btn-icon-text text-dark">
                                       <i class="mdi mdi-chart-pie btn-icon-prepend"></i> Sonuçlar
                                    </a>

                                    <button onclick="deleteSurvey('${survey.id}')" class="btn btn-sm btn-danger btn-icon-text">
                                        <i class="mdi mdi-delete btn-icon-prepend"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                },
                error: function (xhr) {
                    console.error("Anketler yüklenemedi", xhr);
                    $("#surveyTableBody").html('<tr><td colspan="5" class="text-center text-danger">Veriler çekilirken bir hata oluştu!</td></tr>');
                }
            });
        }

        // 3. ANKET SİLME FONKSİYONU
        function deleteSurvey(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu anketi silerseniz içindeki sorular da gidebilir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#b66dff',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "https://localhost:7283/api/survey/" + id,
                        type: "DELETE",
                        success: function () {
                            Swal.fire({
                                icon: 'success',
                                title: 'Silindi!',
                                text: 'Anket başarıyla silindi.',
                                timer: 1500,
                                showConfirmButton: false
                            });

                            loadSurveys();
                        },
                        error: function (xhr) {
                            console.error("Silme hatası:", xhr);
                            Swal.fire('Hata!', 'Anket silinirken bir sorun oluştu.', 'error');
                        }
                    });
                }
            });
        }

        // 4. YENİ ANKET KAYDETME
        $("#btnSaveSurvey").click(function () {
            var titleInput = $("#surveyTitle").val();
            var descriptionInput = $("#surveyDescription").val();
            var categoryIdInput = $("#categoryId").val();

            if (!titleInput || !categoryIdInput) {
                Swal.fire('Uyarı', 'Lütfen Başlık ve Kategori alanlarını doldurunuz!', 'warning');
                return;
            }

            var surveyData = {
                title: titleInput,
                description: descriptionInput,
                categoryId: parseInt(categoryIdInput),
                isActive: true,
                isPublished: false,
                isAnonymous: false,
                createdDate: new Date().toISOString()
            };

            $.ajax({
                url: "https://localhost:7283/api/survey",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(surveyData),
                success: function () {
                    $("#addSurveyModal").modal('hide');
                    $("#surveyTitle").val("");
                    $("#surveyDescription").val("");
                    $("#categoryId").val("");

                    Swal.fire({
                        icon: 'success',
                        title: 'Harika!',
                        text: 'Yeni anket başarıyla oluşturuldu.',
                        timer: 1500,
                        showConfirmButton: false
                    });

                    loadSurveys();
                },
                error: function (xhr) {
                    console.error("Ekleme hatası detayları:", xhr.responseText);
                    Swal.fire('Hata!', 'Anket oluşturulurken bir sorun yaşandı.', 'error');
                }
            });
        });
        $("#btnAddNewCategory").click(function () {
            Swal.fire({
                title: 'Yeni Kategori Ekle',
                input: 'text',
                inputPlaceholder: 'Örn: İnsan Kaynakları',
                showCancelButton: true,
                confirmButtonColor: '#1bcfb4',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Kaydet',
                cancelButtonText: 'İptal',

                target: document.getElementById('addSurveyModal'),

                customClass: {
                    container: 'my-swal-container'
                },
                focusConfirm: false,
                inputValidator: (value) => {
                    if (!value) {
                        return 'Kategori adı boş bırakılamaz!'
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {

                    $.ajax({
                        url: "https://localhost:7283/api/category",
                        type: "POST",
                        contentType: "application/json",
                        data: JSON.stringify({ name: result.value }),
                        success: function () {
                            Swal.fire({
                                icon: 'success',
                                title: 'Eklendi!',
                                text: result.value + ' kategorisi listeye eklendi.',
                                timer: 1500,
                                showConfirmButton: false,
                                target: document.getElementById('addSurveyModal'), // Başarı mesajını da modal içine alıyoruz
                                customClass: { container: 'my-swal-container' }
                            });

                            loadCategories();
                        },
                        error: function (xhr) {
                            console.error("Kategori ekleme hatası:", xhr);
                            Swal.fire({
                                icon: 'error',
                                title: 'Hata!',
                                text: 'Kategori eklenirken bir sorun oluştu.',
                                target: document.getElementById('addSurveyModal'), // Hata mesajını da modal içine alıyoruz
                                customClass: { container: 'my-swal-container' }
                            });
                        }
                    });
                }
            });
        });
    </script>
}