@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-home"></i>
        </span> Yönetici Paneli
    </h3>
</div>

<div class="row">
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-danger card-img-holder text-white shadow">
            <div class="card-body">
                <h4 class="font-weight-normal mb-3">Toplam Anket <i class="mdi mdi-chart-line mdi-24px float-right"></i></h4>
                <h2 class="mb-5" id="dashSurveys">Yükleniyor...</h2>
                <h6 class="card-text">Sistemde kayıtlı anketler</h6>
            </div>
        </div>
    </div>
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-info card-img-holder text-white shadow">
            <div class="card-body">
                <h4 class="font-weight-normal mb-3">Toplam Soru <i class="mdi mdi-bookmark-outline mdi-24px float-right"></i></h4>
                <h2 class="mb-5" id="dashQuestions">0</h2>
                <h6 class="card-text">API entegrasyonu bekleniyor</h6>
            </div>
        </div>
    </div>
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-success card-img-holder text-white shadow">
            <div class="card-body">
                <h4 class="font-weight-normal mb-3">Çözülme Sayısı <i class="mdi mdi-diamond mdi-24px float-right"></i></h4>
                <h2 class="mb-5" id="dashResponses">0</h2>
                <h6 class="card-text">API entegrasyonu bekleniyor</h6>
            </div>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-12 grid-margin">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h4 class="card-title text-dark font-weight-bold mb-4">
                        <i class="mdi mdi-clock-outline text-primary"></i> Son Eklenen Anketler
                    </h4>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="bg-light">
                                <tr>
                                    <th>Anket Başlığı</th>
                                    <th>Oluşturulma Tarihi</th>
                                    <th>Durum</th>
                                    <th>Hızlı İşlem</th>
                                </tr>
                            </thead>
                            <tbody id="latestSurveysTable">
                                <tr>
                                    <td colspan="4" class="text-center text-muted">Veriler Yükleniyor...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $.ajax({
                url: "https://localhost:7283/api/dashboard/stats",
                type: "GET",
                success: function (stats) {
                    $("#dashSurveys").text(stats.totalSurveys);

                    $("#dashQuestions").text(stats.totalQuestions);
                    $("#dashQuestions").next("h6").text("Anketlere eklenen tüm sorular");

                    $("#dashResponses").text(stats.totalResponses);
                    $("#dashResponses").next("h6").text("Kullanıcıların verdiği toplam yanıt");

                    var tbody = $("#latestSurveysTable");
                    tbody.empty();

                    if(stats.latestSurveys.length === 0) {
                         tbody.append('<tr><td colspan="4" class="text-center text-muted">Sistemde henüz anket bulunmuyor.</td></tr>');
                    } else {
                         $.each(stats.latestSurveys, function (index, survey) {
                             var date = new Date(survey.createdDate).toLocaleDateString("tr-TR");

                             var statusBadge = survey.isActive
                                 ? '<label class="badge badge-success">Aktif</label>'
                                 : '<label class="badge badge-secondary">Pasif</label>';

                             tbody.append(`
                                 <tr>
                                     <td class="font-weight-bold">${survey.title}</td>
                                     <td>${date}</td>
                                     <td>${statusBadge}</td>
                                     <td>
                                         <a href="/Admin/Results/${survey.id}" class="btn btn-sm btn-outline-warning text-dark">
                                            <i class="mdi mdi-chart-pie"></i> Sonuçlar
                                         </a>
                                     </td>
                                 </tr>
                             `);
                         });
                    }
                },
                error: function (xhr) {
                    console.error("Dashboard verileri çekilemedi:", xhr);
                    $("#dashSurveys, #dashQuestions, #dashResponses").text("Hata!");
                }
            });
        });
    </script>
}