@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-home"></i>
        </span> Yönetici Paneli
    </h3>
</div>

<div class="row">
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-danger card-img-holder text-white shadow">
            <div class="card-body">
                <h4 class="font-weight-normal mb-3">Toplam Anket <i class="mdi mdi-chart-line mdi-24px float-right"></i></h4>
                <h2 class="mb-5" id="dashSurveys">Yükleniyor...</h2>
                <h6 class="card-text">Sistemde kayıtlı anketler</h6>
            </div>
        </div>
    </div>
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-info card-img-holder text-white shadow">
            <div class="card-body">
                <h4 class="font-weight-normal mb-3">Toplam Soru <i class="mdi mdi-bookmark-outline mdi-24px float-right"></i></h4>
                <h2 class="mb-5" id="dashQuestions">0</h2>
                <h6 class="card-text">API entegrasyonu bekleniyor</h6>
            </div>
        </div>
    </div>
    <div class="col-md-4 stretch-card grid-margin">
        <div class="card bg-gradient-success card-img-holder text-white shadow">
            <div class="card-body">
                <h4 class="font-weight-normal mb-3">Çözülme Sayısı <i class="mdi mdi-diamond mdi-24px float-right"></i></h4>
                <h2 class="mb-5" id="dashResponses">0</h2>
                <h6 class="card-text">API entegrasyonu bekleniyor</h6>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            $.ajax({
                url: "https://localhost:7283/api/survey",
                type: "GET",
                success: function (data) {
                    $("#dashSurveys").text(data.length);
                },
                error: function () {
                    $("#dashSurveys").text("Hata");
                }
            });

            $.ajax({
                url: "https://localhost:7283/api/question",
                type: "GET",
                success: function (data) {
                    $("#dashQuestions").text(data.length);
                    $("#dashQuestions").next("h6").text("Anketlere eklenen tüm sorular");
                },
                error: function () {
                    $("#dashQuestions").text("?");
                    $("#dashQuestions").next("h6").text("API metodunuz kontrol edilmeli");
                }
            });

            $.ajax({
                url: "https://localhost:7283/api/answer", 
                type: "GET",
                success: function (data) {
                    $("#dashResponses").text(data.length);
                    $("#dashResponses").next("h6").text("Kullanıcıların verdiği toplam yanıt");
                },
                error: function () {
                    $("#dashResponses").text("?");
                    $("#dashResponses").next("h6").text("API metodunuz kontrol edilmeli");
                }
            });

        });
    </script>
}