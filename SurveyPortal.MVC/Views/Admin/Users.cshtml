@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-account-multiple"></i>
        </span> Kullanıcı Yönetimi
    </h3>
</div>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="card-title m-0">Sisteme Kayıtlı Kullanıcılar</h4>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>#</th>
                                <th>Kullanıcı Adı</th>
                                <th>E-Posta</th>
                                <th>Rol (Yetki)</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="userTableBody">
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                                    Kullanıcılar yükleniyor...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadUsers();
        });

        function loadUsers() {
            $.ajax({
                url: "https://localhost:7283/api/user",
                type: "GET",
                success: function (data) {
                    var tbody = $("#userTableBody");
                    tbody.empty();

                    if (data.length === 0) {
                        tbody.append('<tr><td colspan="6" class="text-center text-muted py-4">Sistemde henüz kayıtlı kullanıcı yok.</td></tr>');
                        return;
                    }

                    $.each(data, function (index, user) {

                        var roleBadge = user.role === "Admin"
                            ? '<label class="badge badge-gradient-danger px-3 py-2"><i class="mdi mdi-shield-account"></i> Admin</label>'
                            : '<label class="badge badge-gradient-info px-3 py-2"><i class="mdi mdi-account"></i> Kullanıcı</label>';

                        var statusBadge = user.isActive
                            ? '<label class="badge badge-success px-3 py-2">Aktif</label>'
                            : '<label class="badge badge-secondary text-dark px-3 py-2">Pasif</label>';

                        var actionBtn = "";

                            if (user.userName.toLowerCase() === "naz") {
                                actionBtn = `<button class="btn btn-sm btn-secondary btn-icon-text" disabled><i class="mdi mdi-shield-check btn-icon-prepend"></i> Korumalı</button>`;
                            } else {
                            if (user.isActive) {
                                actionBtn = `<button onclick="toggleUserStatus('${user.id}', 'ban')" class="btn btn-sm btn-danger btn-icon-text">
                                                <i class="mdi mdi-cancel btn-icon-prepend"></i> Engelle
                                             </button>`;
                            } else {
                                actionBtn = `<button onclick="toggleUserStatus('${user.id}', 'unban')" class="btn btn-sm btn-success btn-icon-text">
                                                <i class="mdi mdi-check-circle btn-icon-prepend"></i> Aç
                                             </button>`;
                            }
                        }

                        var row = `
                            <tr>
                                <td>${index + 1}</td>
                                <td class="font-weight-bold">${user.userName || "-"}</td>
                                <td>${user.email}</td>
                                <td>${roleBadge}</td>
                                <td>${statusBadge}</td>
                                <td class="d-flex align-items-center">${actionBtn}</td>
                            </tr>
                        `;
                        tbody.append(row);
                    });
                },
                error: function (xhr) {
                    console.error("Kullanıcılar yüklenemedi", xhr);
                    $("#userTableBody").html('<tr><td colspan="6" class="text-center text-danger">Yetkiniz yok veya bir hata oluştu!</td></tr>');
                }
            });
        }

        function toggleUserStatus(id, actionType) {
            var titleText = actionType === 'ban' ? 'Kullanıcıyı Engelle' : 'Engeli Kaldır';
            var confirmText = actionType === 'ban' ? 'Evet, Engelle' : 'Evet, Kaldır';
            var iconType = actionType === 'ban' ? 'warning' : 'question';
            var color = actionType === 'ban' ? '#d33' : '#1bcfb4';

            Swal.fire({
                title: titleText, text: "Emin misiniz?", icon: iconType, showCancelButton: true,
                confirmButtonColor: color, cancelButtonColor: '#6c757d', confirmButtonText: confirmText, cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "https://localhost:7283/api/user/toggle-status/" + id, type: "PUT",
                        success: function (res) {
                            Swal.fire({ icon: 'success', title: 'Başarılı!', text: res.message, timer: 1500, showConfirmButton: false });
                            loadUsers();
                        },
                        error: function () { Swal.fire('Hata!', 'İşlem gerçekleştirilemedi.', 'error'); }
                    });
                }
            });
        }
    </script>
}