@{
    ViewData["Title"] = "Kategori Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-grid"></i>
        </span> Kategori Yönetimi
    </h3>
</div>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="card-title m-0">Sistem Kategorileri</h4>
                    <button class="btn btn-gradient-success btn-sm font-weight-bold" onclick="addNewCategory()">
                        <i class="mdi mdi-plus"></i> Yeni Kategori Ekle
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr class="bg-light">
                                <th>#</th>
                                <th>Kategori Adı</th>
                                <th style="width: 150px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="categoryTableBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadCategoriesPage();
        });

        function loadCategoriesPage() {
            $.ajax({
                url: "https://localhost:7283/api/category",
                type: "GET",
                success: function (data) {
                    var tbody = $("#categoryTableBody");
                    tbody.empty();
                    $.each(data, function (i, cat) {
                        tbody.append(`
                            <tr>
                                <td>${i + 1}</td>
                                <td class="font-weight-bold">${cat.name}</td>
                                <td>
                                    <button onclick="editCategory('${cat.id}', '${cat.name}')" class="btn btn-sm btn-primary me-2">
                                        <i class="mdi mdi-pencil"></i> Düzenle
                                    </button>
                                    <button onclick="deleteCategory('${cat.id}')" class="btn btn-sm btn-danger">
                                        <i class="mdi mdi-delete"></i> Sil
                                    </button>
                                </td>
                            </tr>
                        `);
                    });
                }
            });
        }

        function addNewCategory() {
            Swal.fire({
                title: 'Yeni Kategori',
                input: 'text',
                inputPlaceholder: 'Kategori adını yazın...',
                showCancelButton: true,
                confirmButtonText: 'Kaydet',
                confirmButtonColor: '#1bcfb4',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    $.ajax({
                        url: "https://localhost:7283/api/category",
                        type: "POST",
                        contentType: "application/json",
                        data: JSON.stringify({ name: result.value }),
                        success: function () {
                            showSuccessToast('Kategori başarıyla eklendi.'); // 🔥 TOAST
                            loadCategoriesPage();
                        }
                    });
                }
            });
        }

        function editCategory(id, currentName) {
            Swal.fire({
                title: 'Kategoriyi Düzenle',
                input: 'text',
                inputValue: currentName,
                showCancelButton: true,
                confirmButtonText: 'Güncelle',
                confirmButtonColor: '#b66dff',
                cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed && result.value) {
                    $.ajax({
                        url: "https://localhost:7283/api/category/" + id,
                        type: "PUT",
                        contentType: "application/json",
                        data: JSON.stringify({ id: parseInt(id), name: result.value }),
                        success: function () {
                            showSuccessToast('Kategori başarıyla güncellendi.'); // 🔥 TOAST
                            loadCategoriesPage();
                        },
                        error: function() {
                            showErrorToast('Kategori güncellenemedi.'); // 🔥 TOAST
                        }
                    });
                }
            });
        }

        function deleteCategory(id) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu kategoriyi silmek bağlı anketleri etkileyebilir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#fe7c96',
                confirmButtonText: 'Evet, Sil'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: "https://localhost:7283/api/category/" + id,
                        type: "DELETE",
                        success: function () {
                            showSuccessToast('Kategori başarıyla silindi.'); // 🔥 TOAST
                            loadCategoriesPage();
                        }
                    });
                }
            });
        }
    </script>
}